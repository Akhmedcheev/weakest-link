<Window x:Class="WeakestLink.Views.DarkMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" SizeToContent="WidthAndHeight"
        MinWidth="400" MaxWidth="700" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Border Background="#1E1E1E" BorderBrush="#555" BorderThickness="1" CornerRadius="4" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="#2b2d31" Padding="15,10" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock x:Name="TxtTitle" Text="Уведомление" 
                               Foreground="#dbdee1" FontSize="14" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="28" Height="28" FontSize="14" Foreground="#888" 
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Click="BtnClose_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bg" Background="Transparent" CornerRadius="3">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                  TextBlock.Foreground="{TemplateBinding Foreground}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bg" Property="Background" Value="#da373c"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Message Body -->
            <ScrollViewer Grid.Row="1" MaxHeight="400" VerticalScrollBarVisibility="Auto" Margin="20,15">
                <TextBlock x:Name="TxtMessage" Text="" 
                           Foreground="#dbdee1" FontSize="14" 
                           TextWrapping="Wrap" LineHeight="22"/>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" 
                        Margin="15,5,15,15">
                <Button x:Name="BtnCancel" Content="CANCEL" Visibility="Collapsed"
                        MinWidth="100" Height="36" Margin="0,0,8,0"
                        Background="#4e5058" Foreground="#dbdee1" 
                        FontSize="13" FontWeight="Bold" Cursor="Hand"
                        Click="BtnCancel_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="{TemplateBinding Background}" 
                                                CornerRadius="3" Padding="15,6" BorderBrush="#555" BorderThickness="1">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                                              TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#5a5d63"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="BtnOk" Content="OK"
                        MinWidth="100" Height="36"
                        Background="#5865F2" Foreground="White" 
                        FontSize="13" FontWeight="Bold" Cursor="Hand"
                        Click="BtnOk_Click" IsDefault="True">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="{TemplateBinding Background}" 
                                                CornerRadius="3" Padding="15,6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                                              TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
