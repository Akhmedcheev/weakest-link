<Window x:Class="WeakestLink.Views.QuestionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактор вопросов (QEdit)" Height="650" Width="900"
        Background="#1A1A1A" Foreground="White"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель инструментов -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="BtnLoad" Content="Загрузить из JSON" Width="140" Height="32" Margin="0,0,5,0" Click="BtnLoad_Click"/>
            <Button x:Name="BtnSave" Content="Сохранить в JSON" Width="140" Height="32" Margin="0,0,5,0" Click="BtnSave_Click"/>
            <Button x:Name="BtnAdd" Content="Добавить" Width="90" Height="32" Margin="0,0,5,0" Click="BtnAdd_Click"/>
            <Button x:Name="BtnDelete" Content="Удалить" Width="90" Height="32" Margin="0,0,5,0" Click="BtnDelete_Click"/>
            <Button x:Name="BtnClear" Content="Очистить" Width="90" Height="32" Margin="0,0,5,0" Click="BtnClear_Click"/>
            <TextBlock x:Name="TxtStatus" Text="" Foreground="#888" VerticalAlignment="Center" Margin="15,0,0,0"/>
        </StackPanel>

        <!-- DataGrid с вопросами -->
        <DataGrid x:Name="QuestionsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  Background="#222" Foreground="White" GridLinesVisibility="Horizontal"
                  BorderThickness="1" BorderBrush="#444" Margin="0,0,0,10"
                  SelectionMode="Single" SelectionChanged="QuestionsGrid_SelectionChanged"
                  CanUserAddRows="False" CanUserDeleteRows="False">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#333"/>
                    <Setter Property="Foreground" Value="Yellow"/>
                    <Setter Property="Padding" Value="8,6"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="#222"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#0055AA"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#333"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Текст" Binding="{Binding Text}" Width="*"/>
                <DataGridTextColumn Header="Ответ" Binding="{Binding CorrectAnswer}" Width="120"/>
                <DataGridTextColumn Header="Раунд" Binding="{Binding Round}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Форма редактирования -->
        <GroupBox Grid.Row="2" Header="Редактирование вопроса" Foreground="Yellow" BorderBrush="#444" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Текст:" VerticalAlignment="Top" Margin="0,0,10,5"/>
                <TextBox x:Name="TxtEditText" Grid.Row="0" Grid.Column="1" Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                         Background="#111" Foreground="White" BorderBrush="#555" Margin="0,0,0,5"
                         VerticalScrollBarVisibility="Auto"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Ответ:" VerticalAlignment="Center" Margin="0,0,10,5"/>
                <TextBox x:Name="TxtEditAnswer" Grid.Row="1" Grid.Column="1" Height="28"
                         Background="#111" Foreground="White" BorderBrush="#555" Margin="0,0,0,5"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Раунд:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="TxtEditRound" Grid.Row="2" Grid.Column="1" Height="28" Width="80" HorizontalAlignment="Left"
                         Background="#111" Foreground="White" BorderBrush="#555"/>
            </Grid>
        </GroupBox>

        <!-- Кнопка применить изменения в выбранную строку -->
        <Button Grid.Row="3" x:Name="BtnApplyEdit" Content="Применить изменения к выбранному" Width="220" Height="36" 
                HorizontalAlignment="Left" Click="BtnApplyEdit_Click"/>
    </Grid>
</Window>
