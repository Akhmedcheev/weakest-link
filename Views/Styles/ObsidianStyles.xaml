<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         OBSIDIAN v3.0 COLOR BIBLE — Полная палитра из энциклопедии
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ═══ NEUTRAL COLORS — Базовая схема (Obsidian) ═══ -->
    <SolidColorBrush x:Key="ObsidianBg"            Color="#1E1E1E"/>  <!-- глубокий угольный фон -->
    <SolidColorBrush x:Key="ObsidianSurface"       Color="#252525"/>  <!-- фон карточек и панелей -->
    <SolidColorBrush x:Key="ObsidianCard"          Color="#2D2D2D"/>  <!-- приподнятая карточка -->
    <SolidColorBrush x:Key="ObsidianRaised"        Color="#333333"/>  <!-- еще выше -->
    <SolidColorBrush x:Key="ObsidianBorder"        Color="#363636"/>  <!-- тонкие границы -->
    <SolidColorBrush x:Key="ObsidianBorderLight"   Color="#4D4D4D"/>  <!-- светлая граница (hover) -->

    <!-- ═══ TEXT COLORS — Типографика ═══ -->
    <SolidColorBrush x:Key="ObsidianTextPrimary"   Color="#E0E0E0"/>  <!-- основной текст -->
    <SolidColorBrush x:Key="ObsidianText"          Color="#E8E8E8"/>  <!-- альтернатива (более светлый) -->
    <SolidColorBrush x:Key="ObsidianTextSecondary" Color="#999999"/>  <!-- вторичный/приглушённый -->
    <SolidColorBrush x:Key="ObsidianTextMuted"     Color="#555555"/>  <!-- ещё более приглушённый (labels) -->
    <SolidColorBrush x:Key="ObsidianTextDisabled"  Color="#717171"/>  <!-- disabled state -->

    <!-- ═══ SEMANTIC COLORS — Успех/Ошибка/Предупреждение ═══ -->
    <SolidColorBrush x:Key="ColorSuccess"          Color="#22C55E"/>  <!-- ✅ зелёный (Верно) -->
    <SolidColorBrush x:Key="ColorDanger"           Color="#EF4444"/>  <!-- ❌ красный (Неверно) -->
    <SolidColorBrush x:Key="ColorWarning"          Color="#F59E0B"/>  <!-- ⚠️ жёлтый (Банк/Предупреждение) -->
    <SolidColorBrush x:Key="ColorInfo"             Color="#4F6BED"/>  <!-- ℹ️ синий (Информация) -->

    <!-- ═══ GAME COLORS — Игровые статусы (из Color Bible) ═══ -->
    <SolidColorBrush x:Key="ColorGreen"            Color="#23a559"/>  <!-- Верно (оператор) -->
    <SolidColorBrush x:Key="ColorGold"             Color="#FFD700"/>  <!-- Банк / Деньги / Победитель -->
    <SolidColorBrush x:Key="ColorRed"              Color="#da373c"/>  <!-- Неверно / Опасно -->
    <SolidColorBrush x:Key="ColorBlurple"          Color="#5865F2"/>  <!-- Первичное действие (START) -->
    <SolidColorBrush x:Key="ColorOrange"           Color="#FF8C00"/>  <!-- Предупреждение (Restart) -->
    <SolidColorBrush x:Key="ColorPurple"           Color="#800080"/>  <!-- Debug / Tech -->
    <SolidColorBrush x:Key="ColorTeal"             Color="#2DD4BF"/>  <!-- Accent (checked states) -->

    <!-- ═══ TV-SAFE COLORS — Host Screen (из Color Bible) ═══ -->
    <SolidColorBrush x:Key="TVSafeBackground"      Color="#050510"/>  <!-- глубокий фон Host -->
    <SolidColorBrush x:Key="TVSafeQuestionBg"      Color="#0A1128"/>  <!-- Navy Dark (вопрос) -->
    <SolidColorBrush x:Key="TVSafeAnswer"          Color="#C10000"/>  <!-- Red (ответ) -->
    <SolidColorBrush x:Key="TVSafeTimer"           Color="#006400"/>  <!-- Forest Green (таймер) -->
    <SolidColorBrush x:Key="TVSafeBankNow"         Color="#0000B8"/>  <!-- Royal Blue -->
    <SolidColorBrush x:Key="TVSafeTotal"           Color="#4A0020"/>  <!-- Burgundy -->

    <!-- ═══ ALIASES — Для обратной совместимости ═══ -->
    <SolidColorBrush x:Key="AccentPrimary"         Color="#4F6BED"/>  <!-- синий -->
    <SolidColorBrush x:Key="AccentSuccess"         Color="#22C55E"/>  <!-- зелёный -->
    <SolidColorBrush x:Key="AccentWarning"         Color="#F59E0B"/>  <!-- жёлтый -->
    <SolidColorBrush x:Key="AccentDanger"          Color="#EF4444"/>  <!-- красный -->
    <SolidColorBrush x:Key="ObsidianAccentTeal"    Color="#2DD4BF"/>  <!-- teal -->

    <!-- ═══ BUTTON COLORS — Fire Buttons из Color Bible ═══ -->
    <SolidColorBrush x:Key="FireButtonCorrect"     Color="#23a559"/>  <!-- ВЕРНО -->
    <SolidColorBrush x:Key="FireButtonCorrectHover" Color="#2db86b"/> <!-- ВЕРНО (hover) -->
    <SolidColorBrush x:Key="FireButtonCorrectPress" Color="#1a8a44"/> <!-- ВЕРНО (pressed) -->

    <SolidColorBrush x:Key="FireButtonBank"        Color="#FFD700"/>  <!-- БАНК -->
    <SolidColorBrush x:Key="FireButtonBankHover"   Color="#FFE033"/>  <!-- БАНК (hover) -->
    <SolidColorBrush x:Key="FireButtonBankPress"   Color="#D4B400"/>  <!-- БАНК (pressed) -->

    <SolidColorBrush x:Key="FireButtonWrong"       Color="#da373c"/>  <!-- НЕВЕРНО -->
    <SolidColorBrush x:Key="FireButtonWrongHover"  Color="#e54e52"/>  <!-- НЕВЕРНО (hover) -->
    <SolidColorBrush x:Key="FireButtonWrongPress"  Color="#b82d31"/>  <!-- НЕВЕРНО (pressed) -->

    <SolidColorBrush x:Key="FireButtonPass"        Color="#4e5058"/>  <!-- ПАС -->
    <SolidColorBrush x:Key="FireButtonPassHover"   Color="#5c5e66"/>  <!-- ПАС (hover) -->
    <SolidColorBrush x:Key="FireButtonPassPress"   Color="#3e4046"/>  <!-- ПАС (pressed) -->

    <!-- ═══ MONEY CHAIN COLORS ═══ -->
    <SolidColorBrush x:Key="ChainActive"           Color="#CC8800"/>  <!-- Gold + yellow border (активный уровень) -->
    <SolidColorBrush x:Key="ChainInactive"         Color="#252525"/>  <!-- Dark gray (неактивный уровень) -->

    <!-- ═══ STATUS COLORS ═══ -->
    <SolidColorBrush x:Key="StatusOnline"          Color="#22C55E"/>  <!-- зелёный (играет) -->
    <SolidColorBrush x:Key="StatusWarning"         Color="#F59E0B"/>  <!-- жёлтый (ждёт) -->
    <SolidColorBrush x:Key="StatusOffline"         Color="#717171"/>  <!-- серый (выбыл) -->

    <!-- ═══ NAMED STYLES ONLY (default styles live in OperatorPanel.xaml) ═══ -->

    <!-- ObsidianTextBox: темный ввод с тонкой рамкой -->
    <Style x:Key="ObsidianTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource ObsidianCard}"/>
        <Setter Property="Foreground" Value="{StaticResource ObsidianTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ObsidianBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CaretBrush" Value="{StaticResource ObsidianTextPrimary}"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3" SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost" Focusable="false"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource ColorBlurple}"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource ObsidianBorderLight}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Стиль TextBox с красной подсветкой при фокусе для редактора -->
    <Style x:Key="EditorTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource ObsidianCard}"/>
        <Setter Property="Foreground" Value="{StaticResource ObsidianTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ObsidianBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CaretBrush" Value="{StaticResource ObsidianTextPrimary}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource ColorPurple}"/>
        <Setter Property="Padding" Value="8,2"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3" SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost" Focusable="false"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource ColorDanger}"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource ObsidianBorderLight}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Discord Scrollbar: Thumb -->
    <Style x:Key="DiscordScrollThumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="thumbBorder" Background="{StaticResource ObsidianSurface}" CornerRadius="4"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="thumbBorder" Property="Background" Value="{StaticResource ObsidianBorderLight}"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="thumbBorder" Property="Background" Value="#555555"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Discord Button Style -->
    <Style x:Key="DiscordButton" TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="btnBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid>
                            <Border x:Name="hoverOverlay" Background="White" Opacity="0" CornerRadius="4"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontSize="{TemplateBinding FontSize}"
                                              TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="hoverOverlay" Property="Opacity" Value="0.1"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="hoverOverlay" Property="Opacity" Value="0.0"/>
                            <Setter TargetName="btnBorder" Property="Opacity" Value="0.75"/>
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.98" ScaleY="0.97"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="btnBorder" Property="Opacity" Value="0.45"/>
                            <Setter TargetName="hoverOverlay" Property="Opacity" Value="0"/>
                            <Setter Property="Foreground" Value="#717171"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TestRoundSelector Style -->
    <Style x:Key="TestRoundSelectorStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource ObsidianSurface}"/>
        <Setter Property="Foreground" Value="{StaticResource ObsidianTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ObsidianBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="5,0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton" Grid.Column="2" Focusable="false"
                                      IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="TkBorder" Background="{StaticResource ObsidianSurface}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                                        <Path x:Name="Arrow" Fill="#999" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Data="M0,0 L4,4 L8,0 Z"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TkBorder" Property="BorderBrush" Value="#4D4D4D"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="TkBorder" Property="Background" Value="#333333"/>
                                            <Setter TargetName="TkBorder" Property="BorderBrush" Value="#4D4D4D"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                            <ToggleButton.Background>
                                <TemplateBinding Property="Background"/>
                            </ToggleButton.Background>
                            <ToggleButton.BorderBrush>
                                <TemplateBinding Property="BorderBrush"/>
                            </ToggleButton.BorderBrush>
                            <ToggleButton.BorderThickness>
                                <TemplateBinding Property="BorderThickness"/>
                            </ToggleButton.BorderThickness>
                        </ToggleButton>
                        <TextBlock x:Name="ContentSite" IsHitTestVisible="False"
                                  Text="{TemplateBinding Text}"
                                  Margin="10,0,25,0"
                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  Foreground="{StaticResource ObsidianTextPrimary}"/>

                        <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                            <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <Border x:Name="DropDownBorder" Background="{StaticResource ObsidianSurface}" BorderThickness="1" BorderBrush="{StaticResource ObsidianBorder}" CornerRadius="0,0,3,3" />
                                <ScrollViewer Margin="1" SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Grid>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Алиас для обратной совместимости -->
    <Style x:Key="NoWhiteWhenDisabledButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"/>

    <!-- Стиль игровых кнопок с эффектом физического нажатия -->
    <Style x:Key="GameButtonPressStyle" TargetType="Button">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="#222" BorderThickness="0,0,0,4" Padding="{TemplateBinding Padding}" CornerRadius="5">
                        <ContentPresenter x:Name="content" Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}" HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="BorderThickness" Value="0,2,0,0"/>
                            <Setter TargetName="border" Property="Margin" Value="0,3,0,-3"/>
                            <Setter TargetName="border" Property="Opacity" Value="0.82"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.92"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Flat ToggleButton (без системных рамок) -->
    <Style x:Key="FlatToggleStyle" TargetType="ToggleButton">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="tglBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10"
                            Padding="{TemplateBinding Padding}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"
                                          TextBlock.FontSize="{TemplateBinding FontSize}"
                                          TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="tglBorder" Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="tglBorder" Property="Opacity" Value="0.7"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="tglBorder" Property="BorderBrush" Value="{StaticResource ObsidianAccentTeal}"/>
                            <Setter TargetName="tglBorder" Property="BorderThickness" Value="2"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="tglBorder" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ObsidianCheckBox: тёмный чекбокс в стиле Obsidian -->
    <Style x:Key="ObsidianCheckBox" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource ObsidianTextSecondary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="CheckBorder" Width="18" Height="18" CornerRadius="4"
                                Background="{StaticResource ObsidianRaised}" BorderBrush="{StaticResource ObsidianBorderLight}" BorderThickness="1.5"
                                VerticalAlignment="Center" Margin="0,0,8,0">
                            <TextBlock x:Name="CheckMark" Text="&#xE73E;"
                                       FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{StaticResource ObsidianTextPrimary}" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Visibility="Collapsed"/>
                        </Border>
                        <ContentPresenter VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckBorder" Property="Background" Value="{StaticResource ColorTeal}"/>
                            <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource ColorTeal}"/>
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#64748B"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- FlatButton: Teams-style flat button — Onyx -->
    <Style x:Key="FlatButton" TargetType="Button">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Border x:Name="HoverOverlay" Background="White" Opacity="0" CornerRadius="4"/>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontSize="{TemplateBinding FontSize}"
                                              TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HoverOverlay" Property="Opacity" Value="0.1"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="HoverOverlay" Property="Opacity" Value="0"/>
                            <Setter TargetName="RootBorder" Property="Opacity" Value="0.75"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="RootBorder" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
