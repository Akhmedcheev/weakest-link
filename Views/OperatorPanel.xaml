                    <Grid x:Name="GamePlayPanel" Visibility="Collapsed" Margin="0" Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: Цепочка банка + Раунд -->
                        <Border x:Name="BankChainColumn" Grid.Column="0" Background="#111318" 
                                CornerRadius="8,0,0,8" BorderBrush="#242830" BorderThickness="1,1,0,1">
                            <Grid Margin="0" VerticalAlignment="Stretch">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Text="ЦЕПОЧКА" Foreground="#64748B" FontSize="10" FontWeight="Bold" 
                                           HorizontalAlignment="Center" Margin="0,15,0,5"/>
                                           
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl x:Name="BankChainList" HorizontalAlignment="Stretch" Margin="10,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding Background}" CornerRadius="4" Margin="0,3" Padding="0,8"
                                                        BorderBrush="#2E333D" BorderThickness="1">
                                                    <TextBlock Text="{Binding ValueDisplay}" Foreground="{Binding TextColor}" FontSize="14" FontWeight="Bold" 
                                                               HorizontalAlignment="Center" TextAlignment="Center"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                
                                <!-- Таймер под цепочкой -->
                                <Border Grid.Row="2" Background="#1D2129" CornerRadius="10" 
                                        BorderBrush="#2DD4BF" BorderThickness="1"
                                        Margin="10,8,10,15" Padding="8,6">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="⏱ ВРЕМЯ" Foreground="#2DD4BF" FontSize="9" FontWeight="Bold" 
                                                   HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                        <TextBlock x:Name="TxtTimer" Text="0:00" Foreground="#2DD4BF" 
                                                   FontSize="36" FontWeight="Bold" FontFamily="JetBrains Mono, Consolas"
                                                   HorizontalAlignment="Center">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="#2DD4BF" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- RIGHT: Вопрос + кнопки действий -->
                        <Border Grid.Column="1" Background="#171B22" CornerRadius="0,8,8,0" BorderBrush="#242830" BorderThickness="0,1,1,1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Логотип/заглушка (когда нет вопроса) -->
                                <StackPanel x:Name="LinkLogoPanel" Grid.Row="0" Opacity="0.15" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image Source="/Assets/Images/logotipka.png" Height="150" Stretch="Uniform"/>
                                </StackPanel>

                                <!-- Область вопроса -->
                                <Border x:Name="QuestionCard" Grid.Row="0" Background="#242830" Padding="24,16" Margin="10,10,10,5"
                                        CornerRadius="12" BorderBrush="#2E333D" BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock x:Name="TxtCurrentQuestion" Grid.Row="0" Text="Ожидание вопроса..." 
                                                   Foreground="#E2E8F0" FontSize="28" FontWeight="Bold" 
                                                   TextWrapping="Wrap" TextAlignment="Center" 
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                                   Margin="20,0"/>
                                        <TextBlock x:Name="TxtCurrentAnswer" Grid.Row="1" Text="ОТВЕТ: —" 
                                                   Foreground="#EF4444" FontSize="20" FontWeight="ExtraBold"
                                                   HorizontalAlignment="Center" Margin="0,12,0,5">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="#EF4444" BlurRadius="6" ShadowDepth="0" Opacity="0.3"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <!-- Кнопки действий 2x2 -->
                                <UniformGrid Grid.Row="1" Columns="2" Margin="10,5,10,10">
                                    <Button x:Name="BtnCorrect" Content="✓ ВЕРНО" Height="65" Margin="4" FontSize="22" FontWeight="ExtraBold"
                                            Background="#22C55E" Foreground="White"
                                            Click="BtnCorrect_Click" Style="{StaticResource GameButtonPressStyle}">
                                        <Button.Effect>
                                            <DropShadowEffect Color="#22C55E" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/>
                                        </Button.Effect>
                                    </Button>
                                    <Button x:Name="BtnBank" Content="₽ БАНК" Height="65" Margin="4" FontSize="22" FontWeight="ExtraBold"
                                            Background="#F59E0B" Foreground="#111318"
                                            Click="BtnBank_Click" Style="{StaticResource GameButtonPressStyle}">
                                        <Button.Effect>
                                            <DropShadowEffect Color="#F59E0B" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/>
                                        </Button.Effect>
                                    </Button>
                                    <Button x:Name="BtnWrong" Content="✗ НЕВЕРНО" Height="65" Margin="4" FontSize="22" FontWeight="ExtraBold"
                                            Background="#EF4444" Foreground="White"
                                            Click="BtnWrong_Click" Style="{StaticResource GameButtonPressStyle}">
                                        <Button.Effect>
                                            <DropShadowEffect Color="#EF4444" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/>
                                        </Button.Effect>
                                    </Button>
                                    <Button x:Name="BtnPass" Content="» ПАСС" Height="65" Margin="4" FontSize="22" FontWeight="ExtraBold"
                                            Background="#64748B" Foreground="White"
                                            Click="BtnPass_Click" Style="{StaticResource GameButtonPressStyle}"/>
                                </UniformGrid>

                                <!-- START O'CLOCK -->
                                <Button Grid.Row="2" x:Name="BtnGamePlayPlay" Content="► START O'CLOCK" 
                                        Height="46" FontSize="20" FontWeight="ExtraBold" 
                                        Background="#171B22" Foreground="#333" 
                                        BorderBrush="Transparent" BorderThickness="0" 
                                        Margin="14,0,14,14" 
                                        Click="BtnPlay_Click" Style="{StaticResource GameButtonPressStyle}"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid x:Name="HeadToHeadPanel" Visibility="Collapsed" Background="#111318" Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="10">
                            <Grid.ColumnDefinitions> <ColumnDefinition Width="*"/> <ColumnDefinition Width="*"/> </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="TxtFinalist1" Text="ФИНАЛИСТ 1" FontSize="26" Foreground="Cyan" FontWeight="Black" HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                                    <Ellipse x:Name="P1_C1" Width="20" Height="20" Margin="3" Stroke="White" Fill="Transparent"/>
                                    <Ellipse x:Name="P1_C2" Width="20" Height="20" Margin="3" Stroke="White" Fill="Transparent"/>
                                    <Ellipse x:Name="P1_C3" Width="20" Height="20" Margin="3" Stroke="White" Fill="Transparent"/>
                                    <Ellipse x:Name="P1_C4" Width="20" Height="20" Margin="3" Stroke="White" Fill="Transparent"/>
                                    <Ellipse x:Name="P1_C5" Width="20" Height="20" Margin="3" Stroke="White" Fill="Transparent"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="TxtFinalist2" Text="ФИНАЛИСТ 2" FontSize="26" Foreground="Cyan" FontWeight="Black" HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                                    <Ellipse x:Name="P2_C1" Width="20" Height="20" Margin="3" Stroke="White" Fill="Transparent"/>
                                    <Ellipse x:Name="P2_C2" Width="20" Height="20" Margin="3" Stroke="White" Fill="Transparent"/>
                                    <Ellipse x:Name="P2_C3" Width="20" Height="20" Margin="3" Stroke="White" Fill="Transparent"/>
                                    <Ellipse x:Name="P2_C4" Width="20" Height="20" Margin="3" Stroke="White" Fill="Transparent"/>
                                    <Ellipse x:Name="P2_C5" Width="20" Height="20" Margin="3" Stroke="White" Fill="Transparent"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <Grid Grid.Row="1">
                            <Border x:Name="FinalPrestartBorder" Background="#1A2A1A" Margin="10,5" Padding="12" CornerRadius="5" BorderBrush="#3A4050" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Кто отвечает первым?" Foreground="#AAA" FontSize="14" Margin="0,0,0,8"/>
                                    <ComboBox x:Name="CmbFirstResponder" Height="36" FontSize="16" Margin="0,0,0,10"/>
                                    <Button x:Name="BtnApplyDuel" Content="ПРИМЕНИТЬ" Background="#00AA00" Foreground="White" Height="50" FontWeight="Bold" Click="BtnApplyDuel_Click" Style="{StaticResource NoWhiteWhenDisabledButtonStyle}"/>
                                </StackPanel>
                            </Border>
                            <Button x:Name="BtnStartDuel" Content="СТАРТ ДУЭЛИ" Background="#00AA00" Foreground="White" Height="50" FontWeight="Bold" Margin="10,5" VerticalAlignment="Top" Visibility="Collapsed" Click="BtnStartDuel_Click" Style="{StaticResource NoWhiteWhenDisabledButtonStyle}"/>
                        </Grid>
                        <Border Grid.Row="2" Background="#1D2129" Margin="10,5" Padding="15" CornerRadius="10" MinHeight="150">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="TurnTextBlock" Text="ОЧЕРЕДЬ: ИГРОК 1" Foreground="Yellow" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="FinalQuestionTextBlock" Text="ВОПРОС ФИНАЛА" Foreground="White" FontSize="24" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center" Margin="0,5"/>
                                <TextBlock x:Name="TxtDuelAnswer" Text="ОТВЕТ: —" Foreground="#00FFCC" FontSize="22" FontWeight="ExtraBold" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <UniformGrid Grid.Row="3" Columns="2" Margin="10">
                            <Button x:Name="BtnDuelCorrect" Content="ВЕРНО" Background="#006600" Foreground="White" Height="70" FontSize="24" FontWeight="Bold" Margin="5" Click="BtnDuelCorrect_Click" Style="{StaticResource NoWhiteWhenDisabledButtonStyle}"/>
                            <Button x:Name="BtnDuelWrong" Content="НЕВЕРНО" Background="#AA0000" Foreground="White" Height="70" FontSize="24" FontWeight="Bold" Margin="5" Click="BtnDuelWrong_Click" Style="{StaticResource NoWhiteWhenDisabledButtonStyle}"/>
                        </UniformGrid>
                    </Grid>

                    <!-- 4. ПОБЕДА -->
                    <Grid x:Name="WinnerPanel" Grid.Row="0" Grid.RowSpan="3" Visibility="Collapsed" Background="#171B22">
                        <Border Background="#242830" CornerRadius="12" Padding="48,36" 
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                MaxWidth="500" BorderBrush="#3a3c42" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="ПОБЕДИТЕЛЬ" Foreground="#949BA4" FontSize="12" FontWeight="Bold" 
                                           HorizontalAlignment="Center" Margin="0,0,0,8" FontFamily="Segoe UI"/>
                                <TextBlock x:Name="TxtFinalWinnerName" Text="ИМЯ" Foreground="#F2F3F5" 
                                           FontSize="56" FontWeight="ExtraBold" HorizontalAlignment="Center" 
                                           FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                <Border Height="1" Background="#242830" Margin="20,8,20,12"/>
                                <TextBlock x:Name="TxtFinalWinnings" Text="0 ₽" Foreground="#3B82F6" 
                                           FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" 
                                           Margin="0,0,0,20" FontFamily="Segoe UI"/>
                                <Button x:Name="BtnEndShow" Content="ЗАВЕРШИТЬ ИГРУ" 
                                        Background="#3B82F6" BorderThickness="0" 
                                        Foreground="White" FontSize="15" FontFamily="Segoe UI" FontWeight="SemiBold"
                                        Padding="40,12" HorizontalAlignment="Center"
                                        Click="BtnEndShow_Click" Style="{StaticResource NoWhiteWhenDisabledButtonStyle}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    </Grid>
                    
                    <!-- TRANSITION OVERLAY -->
                    <Grid x:Name="TransitionOverlay" Visibility="Collapsed" Background="#111318">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtTransitionTitle" Text="ИТОГИ РАУНДА" 
                                       Foreground="#3B82F6" FontSize="28" FontWeight="ExtraBold" 
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtTransitionSub" Text="Переход к аналитике..." 
                                       Foreground="#64748B" FontSize="14" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- 2. ANALYTICS CONTEXT - Dashboard -->
                    <Grid x:Name="AnalyticsContext" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Заголовок -->
                        <Border Grid.Row="0" Background="Transparent" Padding="15,12" BorderBrush="#2E333D" BorderThickness="0,0,0,1">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="ANALYTICS" Foreground="{StaticResource ObsidianTextPrimary}" 
                                              FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="ПРОГНОЗ ВЫБЫВАНИЯ" Foreground="#FF6B6B" FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.8"/>
                            </Grid>
                        </Border>

                        <!-- Ключевые метрики (компактные) -->
                        <UniformGrid Grid.Row="1" Columns="4" Margin="8,8,8,4">
                            <Border Background="#171B22" CornerRadius="6" Padding="8,6" Margin="3">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="ИГРЫ" Foreground="#64748B" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtAnalyticsTotalGames" Text="0" Foreground="#3B82F6" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#171B22" CornerRadius="6" Padding="8,6" Margin="3">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="СР. БАНК" Foreground="#64748B" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtAnalyticsAvgBank" Text="0 ₽" Foreground="#00FF00" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#171B22" CornerRadius="6" Padding="8,6" Margin="3">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="MVP" Foreground="#64748B" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtAnalyticsBestPlayer" Text="—" Foreground="#FFD700" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#171B22" CornerRadius="6" Padding="8,6" Margin="3">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="ВРЕМЯ" Foreground="#64748B" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtAnalyticsPlayTime" Text="00:00" Foreground="#FF6B6B" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                        
                        <!-- Таблица игроков (прозрачная) -->
                        <Border Grid.Row="2" Background="Transparent" Margin="8,4,8,8" Padding="0">
                            <DataGrid x:Name="AnalyticsPlayersGrid" 
                                     Background="Transparent" 
                                     Foreground="{StaticResource ObsidianTextPrimary}"
                                     GridLinesVisibility="Horizontal" 
                                     HorizontalGridLinesBrush="#262626"
                                     VerticalGridLinesBrush="Transparent"
                                     HeadersVisibility="Column"
                                     AutoGenerateColumns="False"
                                     CanUserAddRows="False" CanUserDeleteRows="False"
                                     CanUserReorderColumns="False" CanUserSortColumns="True"
                                     SelectionMode="Single" IsReadOnly="True"
                                     AlternatingRowBackground="Transparent"
                                     RowBackground="Transparent"
                                     BorderThickness="0">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="#363636"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="Foreground" Value="#aaa"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="Padding" Value="8,6"/>
                                    </Style>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1e1f22"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#dbdee1"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="Padding" Value="8,4"/>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ИГРОК" Width="140" Binding="{Binding Name}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="ВЕРНО" Width="70" Binding="{Binding CorrectAnswers}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#2ecc71"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="TextAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="НЕВЕРНО" Width="80" Binding="{Binding WrongAnswers}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#e74c3c"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="TextAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="ПОТЕРИ" Width="80" Binding="{Binding MoneyLost, StringFormat=N0}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#ff6b6b"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="TextAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="ПАССЫ" Width="65" Binding="{Binding PassCount}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#a0a0a0"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="TextAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="БАНК" Width="80" Binding="{Binding BankedAmount}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#f1c40f"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="TextAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="ПРОГНОЗ" Width="*" Binding="{Binding Prediction}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FF6B6B"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="TextAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Decision Hub -->
                        <Border Grid.Row="3" Background="#111318" BorderBrush="#2E333D" BorderThickness="0,1,0,0" Padding="10,6">
                            <StackPanel>
                                <!-- Voting duration selector -->
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="ТАЙМЕР ГОЛОСОВАНИЯ" Foreground="#444" FontSize="10" FontWeight="Bold" 
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox x:Name="CmbVotingDuration" Grid.Column="1" Height="24" FontSize="11" 
                                              Background="#171B22" Foreground="#E2E8F0" BorderThickness="0" SelectedIndex="0">
                                        <ComboBoxItem Content="0:45 (стандарт)" Tag="45"/>
                                        <ComboBoxItem Content="1:00" Tag="60"/>
                                        <ComboBoxItem Content="1:30" Tag="90"/>
                                        <ComboBoxItem Content="2:00" Tag="120"/>
                                    </ComboBox>
                                </Grid>

                                <!-- Voting Stepper -->
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="1.3*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="BtnStartVoting" Grid.Column="0" Content="① VOTE" Height="36" Margin="0,0,2,0"
                                            Background="Transparent" BorderBrush="#2E333D" BorderThickness="1"
                                            Foreground="#444" FontWeight="Bold" FontSize="11" Opacity="0.4"
                                            IsEnabled="False" Click="BtnStartVoting_Click" Style="{StaticResource FlatButton}"/>
                                    <Button x:Name="BtnEndVoting" Grid.Column="1" Content="② END" Height="36" Margin="2,0"
                                            Background="Transparent" BorderBrush="#2E333D" BorderThickness="1"
                                            Foreground="#444" FontWeight="Bold" FontSize="11" Opacity="0.4"
                                            IsEnabled="False" Click="BtnEndVoting_Click" Style="{StaticResource FlatButton}"/>
                                    <Button x:Name="BtnReveal" Grid.Column="2" Content="③ REVEAL" Height="36" Margin="2,0"
                                            Background="Transparent" BorderBrush="#2E333D" BorderThickness="1"
                                            Foreground="#444" FontWeight="Bold" FontSize="11" Opacity="0.4"
                                            IsEnabled="False" Click="BtnReveal_Click" Style="{StaticResource FlatButton}"/>
                                    <Button x:Name="BtnHotDiscussion" Grid.Column="3" Content="④ VERDICT" Height="36" Margin="2,0,0,0"
                                            BorderBrush="#2E333D" BorderThickness="1"
                                            Foreground="#444" FontWeight="Bold" FontSize="12" Opacity="0.4"
                                            IsEnabled="False" Click="BtnHotDiscussion_Click" Style="{StaticResource FlatButton}">
                                        <Button.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#1a1a1e" Offset="0"/>
                                                <GradientStop Color="#121214" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Button.Background>
                                    </Button>
                                </Grid>

                                <!-- Reveal Timeline -->
                                <Border x:Name="RevealProgressPanel" Background="#0D0D18" CornerRadius="5" Margin="0,2,0,4" Padding="10,8" Visibility="Collapsed">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="TxtRevealPhase" Text="ИНТРО ВЕДУЩЕЙ" Foreground="#FFD700" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtRevealTime" Text="0:00 / 0:00" Foreground="#777" FontSize="11" Grid.Column="2" VerticalAlignment="Center"/>
                                        </Grid>
                                        <!-- Segmented timeline background -->
                                        <Grid Height="6" Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="16*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#1a1a3a" CornerRadius="3,0,0,3"/>
                                            <Border Grid.Column="1" Background="#0a2a0a" CornerRadius="0,3,3,0"/>
                                        </Grid>
                                        <ProgressBar x:Name="RevealProgress" Height="6" Margin="0,-10,0,0"
                                                     Minimum="0" Maximum="100" Value="0" 
                                                     Background="Transparent" Foreground="#FFD700"
                                                     BorderThickness="0"/>
                                        <Grid Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#141428" CornerRadius="3" Padding="4,2" Margin="0,0,2,0">
                                                <TextBlock Text="ИНТРО" Foreground="#3B82F6" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </Border>
                                            <Border x:Name="RevealCueMarker" Grid.Column="1" Background="#0a1e0a" CornerRadius="3" Padding="4,2" Margin="2,0,0,0">
                                                <TextBlock Text="▶ ВСКРЫТИЕ" Foreground="#2ecc71" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Elimination row -->
                                <Border x:Name="VotingBorder" Background="#1a0a0a" CornerRadius="5" Margin="0,2" Padding="10,8" 
                                        Visibility="Collapsed" BorderBrush="#2a1515" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="ИСКЛЮЧИТЬ:" Foreground="#aa4444" FontSize="11" FontWeight="Bold" 
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox x:Name="EliminationComboBox" Grid.Column="1" Height="30" FontSize="13" 
                                                  Background="#111318" Foreground="#E2E8F0" BorderThickness="0" Margin="0,0,6,0"
                                                  SelectionChanged="EliminationComboBox_SelectionChanged">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}" Foreground="{Binding TextColor}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Button x:Name="BtnEliminate" Grid.Column="2" Content="ELIMINATE" Width="110" Height="30"
                                                BorderBrush="#EF4444" BorderThickness="1.5"
                                                Foreground="#da373c" FontWeight="Bold" FontSize="11"
                                                Click="BtnEliminate_Click" Style="{StaticResource FlatButton}">
                                            <Button.Background>
                                                <SolidColorBrush Color="#00000000"/>
                                            </Button.Background>
                                            <Button.Triggers>
                                                <EventTrigger RoutedEvent="MouseEnter">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)"
                                                                            To="#4a1515" Duration="0:0:0.15"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <EventTrigger RoutedEvent="MouseLeave">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)"
                                                                            To="#00000000" Duration="0:0:0.2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Button.Triggers>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Final transition -->
                                <Button x:Name="BtnToFinal" Content="ПЕРЕЙТИ К ФИНАЛУ" Height="36" Margin="0,4,0,0"
                                        Background="#00AA00" Foreground="White" FontWeight="Bold" FontSize="12"
                                        Visibility="Collapsed" Click="BtnToFinal_Click" Style="{StaticResource FlatButton}"/>

                                <!-- Close round -->
                                <Button x:Name="BtnCloseRoundFromAnalytics" Content="CLOSE ROUND" Height="32" Margin="0,4,0,0"
                                        Background="Transparent" BorderBrush="#2E333D" BorderThickness="1"
                                        Foreground="#64748B" FontWeight="Bold" FontSize="10"
                                        Click="BtnNextRound_Click" Style="{StaticResource FlatButton}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    
                    <!-- 3. EDITOR CONTEXT - Редактор вопросов -->
                    <Grid x:Name="EditorContext" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- TOOLBAR -->
                        <Border Grid.Row="0" Background="Transparent" BorderBrush="#242830" BorderThickness="0,0,0,1" Padding="10,7">
                            <Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Button x:Name="BtnEditorNew" Content="＋ НОВЫЙ" Height="28" Padding="10,0" Margin="0,0,4,0"
                                           Background="Transparent" BorderBrush="#2E333D" BorderThickness="1"
                                           Foreground="#94A3B8" FontSize="11" FontWeight="Bold"
                                           Click="BtnEditorNew_Click" Style="{StaticResource FlatButton}"/>
                                    <Button x:Name="BtnEditorDelete" Content="✕ УДАЛИТЬ" Height="28" Padding="10,0" Margin="0,0,4,0"
                                           Background="Transparent" BorderBrush="#2E333D" BorderThickness="1"
                                           Foreground="#da373c" FontSize="11" FontWeight="Bold"
                                           Click="BtnEditorDelete_Click" Style="{StaticResource FlatButton}"/>
                                    <Button x:Name="BtnEditorLoad" Content="ЗАГРУЗИТЬ" Height="28" Padding="10,0" Margin="0,0,4,0"
                                           Background="Transparent" BorderBrush="#2E333D" BorderThickness="1"
                                           Foreground="#94A3B8" FontSize="11" FontWeight="Bold"
                                           Click="BtnEditorLoad_Click" Style="{StaticResource FlatButton}"/>
                                    <Button x:Name="BtnEditorSave" Content="СОХРАНИТЬ" Height="28" Padding="10,0" Margin="0,0,4,0"
                                           Background="Transparent" BorderBrush="#2E333D" BorderThickness="1"
                                           Foreground="#94A3B8" FontSize="11" FontWeight="Bold"
                                           Click="BtnEditorSave_Click" Style="{StaticResource FlatButton}"/>
                                    <TextBlock x:Name="TxtEditorSaveToast" Text="" Foreground="#2ecc71" FontSize="11" FontWeight="Bold"
                                               VerticalAlignment="Center" Margin="8,0,0,0" Opacity="0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBox x:Name="TxtEditorSearch" Width="180" Height="28"
                                            Background="#111318" BorderBrush="#2E333D" BorderThickness="1"
                                            Foreground="#E2E8F0" Padding="8,0"
                                            VerticalContentAlignment="Center" FontSize="12"
                                            Style="{StaticResource EditorTextBoxStyle}"/>
                                    <Button x:Name="BtnEditorSearch" Content="ПОИСК" Height="28" Padding="10,0" Margin="4,0,0,0"
                                           Background="Transparent" BorderBrush="#2E333D" BorderThickness="1"
                                           Foreground="#94A3B8" FontSize="11" FontWeight="Bold"
                                           Style="{StaticResource FlatButton}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- DATA: DataGrid -->
                        <DataGrid Grid.Row="1" x:Name="QuestionsDataGrid"
                                 Background="Transparent"
                                 Foreground="#E2E8F0"
                                 GridLinesVisibility="None"
                                 HeadersVisibility="Column"
                                 AutoGenerateColumns="False"
                                 CanUserAddRows="False" CanUserDeleteRows="False"
                                 CanUserReorderColumns="False" CanUserResizeColumns="True"
                                 CanUserResizeRows="False" CanUserSortColumns="True"
                                 SelectionMode="Single" SelectionUnit="FullRow" FontSize="13"
                                 SelectionChanged="QuestionsDataGrid_SelectionChanged"
                                 AlternatingRowBackground="Transparent"
                                 RowBackground="Transparent"
                                 BorderThickness="0" Margin="8,4,8,0"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Foreground" Value="#808080"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="10"/>
                                    <Setter Property="Padding" Value="8,6"/>
                                </Style>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="MinHeight" Value="32"/>
                                    <Setter Property="Margin" Value="0,1"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#18da373c"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#0cffffff"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Foreground" Value="#dbdee1"/>
                                    <Setter Property="Padding" Value="8,5"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                    <ContentPresenter/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ВОПРОС" Binding="{Binding Text}" Width="*" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#dbdee1"/>
                                            <Setter Property="TextWrapping" Value="NoWrap"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="ОТВЕТ" Binding="{Binding Answer}" Width="180" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#da373c"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="ДОП. ДОПУЩЕНИЯ" Binding="{Binding AcceptableAnswers}" Width="150" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#666"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="РАУНД" Binding="{Binding Round}" Width="70" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#555"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- FORM: Edit card -->
                        <Border Grid.Row="2" Background="#111318" BorderBrush="#242830" BorderThickness="0,1,0,0"
                                CornerRadius="8,8,0,0" Margin="8,0,8,0" Padding="12,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="180"/>
                                    </Grid.ColumnDefinitions>
                                     <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                        <TextBlock Text="ВОПРОС" FontSize="10" Foreground="#64748B" FontWeight="Bold" Margin="2,0,0,2"/>
                                        <TextBox x:Name="TxtEditQuestion" Style="{StaticResource EditorTextBoxStyle}" Height="32" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="ОТВЕТ" FontSize="10" Foreground="#da373c" FontWeight="Bold" Margin="2,0,0,2"/>
                                        <TextBox x:Name="TxtEditAnswer" Style="{StaticResource EditorTextBoxStyle}" Foreground="#da373c" Height="32" FontWeight="Bold" FontSize="12"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                     <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                        <TextBlock Text="ДОП. ДОПУЩЕНИЯ" FontSize="10" Foreground="#64748B" FontWeight="Bold" Margin="2,0,0,2"/>
                                        <TextBox x:Name="TxtEditAccept" Style="{StaticResource EditorTextBoxStyle}" Height="32" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,6,0">
                                        <TextBlock Text="РАУНД" FontSize="10" Foreground="#64748B" FontWeight="Bold" Margin="2,0,0,2"/>
                                        <TextBox x:Name="TxtEditRound" Style="{StaticResource EditorTextBoxStyle}" Height="32" HorizontalContentAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                    <Button x:Name="BtnEditorApply" Grid.Column="2" Content="ПРИМЕНИТЬ" 
                                            Height="32" Padding="16,0" VerticalAlignment="Bottom"
                                            Background="#EF4444" Foreground="White" 
                                            FontWeight="Bold" FontSize="11"
                                            Click="BtnEditorApply_Click"
                                            Style="{StaticResource FlatButton}"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ПРАВАЯ КОЛОНКА: Панель управления -->
                <Border Grid.Column="2" Background="{StaticResource ObsidianSurface}" BorderBrush="{StaticResource ObsidianBorder}" BorderThickness="1,0,0,0" Margin="0" CornerRadius="12,0,0,0" Padding="15,20,15,20" Panel.ZIndex="10">
                    <DockPanel LastChildFill="True">
                        <!-- Низ правой панели: Паника -->
                        <StackPanel DockPanel.Dock="Bottom">
                            <Button x:Name="BtnPanic" Content="! ПАНИКА !" Background="#EF4444" Foreground="White" Height="45" FontWeight="Black" Margin="2,4" Click="BtnPanic_Click" Style="{StaticResource FlatButton}"/>
                        </StackPanel>

                        <!-- Основное содержимое правой панели (без скролла) -->
                        <StackPanel Margin="0">
                        <TextBlock Text="УПРАВЛЕНИЕ ЭФИРОМ" Foreground="#94A3B8" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                        <!-- ▶ УПРАВЛЕНИЕ РАУНДОМ -->
                        <Border Background="#1D2129" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="▶ РАУНД" Foreground="#64748B" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <UniformGrid Columns="2">
                                    <Button Content="READY" x:Name="BtnStartRound" Background="#22C55E" Foreground="White" FontWeight="Bold" Height="40" Margin="2" Click="BtnReady_Click" Style="{StaticResource FlatButton}"/>
                                    <Button Content="START O'CLOCK" x:Name="BtnPlay" Background="#3B82F6" Foreground="White" FontWeight="Bold" Height="40" Margin="2" Click="BtnPlay_Click" Style="{StaticResource FlatButton}"/>
                                </UniformGrid>
                                <Button Content="CLOSE ROUND" x:Name="BtnNextRound" Background="#2E333D" Foreground="#E2E8F0" Height="34" Margin="2,6,2,0" Click="BtnNextRound_Click" Style="{StaticResource FlatButton}"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Decision Hub кнопки перенесены в AnalyticsContext -->
                        
                        <!-- УДалена кнопка RESET IDLE - она дублирует функционал CLOSE ROUND и ломает логику финалов -->

                        <!-- 📺 ГРАФИКА БРОДКАСТА -->
                        <Border Background="#1D2129" CornerRadius="10" Padding="10" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="📺 ГРАФИКА БРОДКАСТА" Foreground="#94A3B8" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <Button x:Name="BtnLogo" Height="30" Margin="0,0,0,4" Click="BtnLogo_Click" Style="{StaticResource FlatButton}"
                                        Background="#1D2129" BorderBrush="#2E333D" BorderThickness="1" 
                                        ToolTip="ВКЛ/ВЫКЛ ЛОГОТИП НА ЭКРАНАХ">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Images/logotipka.png" Height="18" Margin="0,0,6,0" Stretch="Uniform"/>
                                        <TextBlock Text="ЛОГОТИП" Foreground="{StaticResource ObsidianTextPrimary}" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <UniformGrid Columns="2" Margin="0,0,0,6">
                                    <Button x:Name="BtnStyleClassic" Content="🎨 CLASSIC" Height="26" Margin="2"
                                            Background="#2E333D" Foreground="#E2E8F0" FontWeight="Bold" FontSize="10"
                                            Click="BtnBcStyleClassic_Click" Style="{StaticResource FlatButton}"/>
                                    <Button x:Name="BtnStyleNew" Content="✨ NEW" Height="26" Margin="2"
                                            Background="#3B82F6" Foreground="White" FontWeight="Bold" FontSize="10"
                                            Click="BtnBcStyleNew_Click" Style="{StaticResource FlatButton}"/>
                                </UniformGrid>
                                <TextBlock Text="РАУНД" Foreground="#64748B" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                <UniformGrid Columns="3">
                                    <ToggleButton x:Name="TglBcTimer" Content="⏱ ТАЙМЕР" Height="32" Margin="2"
                                                  Background="#242830" Foreground="#2DD4BF" FontWeight="Bold" FontSize="10"
                                                  Click="TglBcTimer_Click" Style="{StaticResource FlatToggleStyle}"/>
                                    <ToggleButton x:Name="TglBcChain" Content="💰 ЦЕПОЧКА" Height="32" Margin="2"
                                                  Background="#242830" Foreground="#2DD4BF" FontWeight="Bold" FontSize="10"
                                                  Click="TglBcChain_Click" Style="{StaticResource FlatToggleStyle}"/>
                                    <ToggleButton x:Name="TglBcChainTimer" Content="⏱💰 ВСЁ" Height="32" Margin="2"
                                                  Background="#242830" Foreground="#2DD4BF" FontWeight="Bold" FontSize="10"
                                                  Click="TglBcChainTimer_Click" Style="{StaticResource FlatToggleStyle}"/>
                                </UniformGrid>
                                <TextBlock Text="ОВЕРЛЕИ" Foreground="#64748B" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,6,0,3"/>
                                <UniformGrid Columns="2">
                                    <ToggleButton x:Name="TglBcBank" Content="💰 БАНК" Height="32" Margin="2"
                                                  Background="#1B5E20" Foreground="#A5D6A7" FontWeight="Bold" FontSize="10"
                                                  Click="TglBcBank_Click" Style="{StaticResource FlatToggleStyle}"/>
                                    <ToggleButton x:Name="TglBcDuel" Content="🎯 ДУЭЛЬ" Height="32" Margin="2"
                                                  Background="#4A148C" Foreground="#CE93D8" FontWeight="Bold" FontSize="10"
                                                  Click="TglBcDuel_Click" Style="{StaticResource FlatToggleStyle}"/>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Code-behind write targets: referenced in state handlers, will be promoted to visible UI -->
            <Grid Visibility="Collapsed">
                <Button x:Name="BtnIntro1"/><Button x:Name="BtnIntro2"/><Button x:Name="BtnNextQuestion"/>
                <Button x:Name="BtnOpening"/><Button x:Name="BtnIncorrect"/><Button x:Name="BtnRulesIntro"/>
                <DataGrid x:Name="PlayersGrid"><DataGrid.Columns><DataGridTextColumn x:Name="VotedForColumn"/></DataGrid.Columns></DataGrid>
                <StackPanel x:Name="PreGamePanel"/><TextBlock x:Name="RemoteLinkText"/>
                <Border x:Name="RoundBankPanel"/><TextBlock x:Name="StartingPlayerTextBlock"/>
                <Border x:Name="StatusBarBorder"/><StackPanel x:Name="TimerPanel"/>
                <TextBlock x:Name="TxtGameState"/><TextBlock x:Name="TxtRound"/>
                <TextBlock x:Name="TxtRoundBank"/><TextBlock x:Name="TxtStatusAction"/>
                <TextBlock x:Name="TxtStatusHint"/><TextBlock x:Name="TxtStatusProcess"/>
                <TextBlock x:Name="TxtTimerLabel"/>
                <Button x:Name="BtnBotTurn"/><ToggleButton x:Name="TglAutoBot"/>
                <Button x:Name="BtnBotGameSemiAuto"/><Button x:Name="BtnBotGameAuto"/>
                <Button x:Name="BtnDebugEndRoundTimer"/>
                <Border x:Name="PreGameButtons"/><Button x:Name="BtnOpeningUI"/><Button x:Name="BtnIntro1UI"/><Button x:Name="BtnIntro2UI"/><Button x:Name="BtnRulesUI"/>
             </Grid>

            <!-- ОВЕРЛЕЙ: Терминал логов (перекрывает, не сдвигает) -->
            <Border x:Name="LogContainer" Grid.Row="3" VerticalAlignment="Bottom" Panel.ZIndex="100"
                    Background="{StaticResource ObsidianBg}" 
                    BorderBrush="{StaticResource ObsidianBorder}" BorderThickness="0,1,0,0"
                    MaxHeight="200" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="ЛОГ СОБЫТИЙ" Foreground="#5a6" FontSize="12" FontFamily="Consolas" FontWeight="Bold" Margin="10,5,0,3"/>
                    <ListBox Grid.Row="1" x:Name="LstLog" 
                             Background="{StaticResource ObsidianBg}" 
                             Foreground="{StaticResource ObsidianTextSecondary}" 
                             BorderThickness="0" Padding="10,2" Margin="0"
                             FontFamily="Consolas" FontSize="12"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.Resources>
                            <Style TargetType="ScrollBar">
                                <Setter Property="OverridesDefaultStyle" Value="True"/>
                                <Setter Property="Width" Value="8"/>
                                <Setter Property="MinWidth" Value="8"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ScrollBar">
                                            <Grid Background="Transparent">
                                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                    <Track.Thumb>
                                                        <Thumb>
                                                            <Thumb.Template>
                                                                <ControlTemplate TargetType="Thumb">
                                                                    <Border x:Name="tb" Background="#2E333D" CornerRadius="4"/>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="tb" Property="Background" Value="#3A4050"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Thumb.Template>
                                                        </Thumb>
                                                    </Track.Thumb>
                                                </Track>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="Orientation" Value="Horizontal">
                                        <Setter Property="Width" Value="Auto"/>
                                        <Setter Property="Height" Value="8"/>
                                        <Setter Property="MinHeight" Value="8"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ScrollBar">
                                                    <Grid Background="Transparent">
                                                        <Track x:Name="PART_Track" IsDirectionReversed="False">
                                                            <Track.Thumb>
                                                                <Thumb>
                                                                    <Thumb.Template>
                                                                        <ControlTemplate TargetType="Thumb">
                                                                            <Border x:Name="tb" Background="#2E333D" CornerRadius="4"/>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="tb" Property="Background" Value="#3A4050"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Thumb.Template>
                                                                </Thumb>
                                                            </Track.Thumb>
                                                        </Track>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Resources>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="2,1"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
        </Grid>

        <!-- Row 2: Obsidian Status Bar -->
        <Border Grid.Row="2" Background="#171B22" BorderBrush="{StaticResource ObsidianBorder}" BorderThickness="0,1,0,0">
            <Grid>
                <!-- Левая часть статус-бара -->
                <TextBlock x:Name="TxtStatusBarInfo" Text="Weakest Link — Operator" 
                           Foreground="{StaticResource ObsidianTextSecondary}" FontSize="11" 
                           VerticalAlignment="Center" Margin="10,0,0,0" HorizontalAlignment="Left"/>
                <!-- Правая часть: кнопка логов -->
                <Button x:Name="BtnToggleLogs" Click="BtnToggleLogs_Click"
                        HorizontalAlignment="Right" VerticalAlignment="Stretch"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Padding="12,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#242830"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock x:Name="TxtLogToggleLabel" Text="[&gt;_] Логи" 
                               Foreground="{StaticResource ObsidianTextSecondary}" FontSize="11" FontFamily="Consolas"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
