<Window x:Class="WeakestLink.Views.OperatorPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Weakest Link - Operator Panel" Height="1000" Width="1400"
        Background="{DynamicResource ObsidianBg}" Foreground="{DynamicResource ObsidianTextPrimary}"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="None"
        AllowsTransparency="True"
        KeyDown="Window_KeyDown">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ═══ OBSIDIAN v2.0 PALETTE — Charcoal Premium ═══ -->
        <SolidColorBrush x:Key="ObsidianBg"            Color="#111318"/>  <!-- 00 dp — глубокий уголь -->
        <SolidColorBrush x:Key="ObsidianSurface"       Color="#171B22"/>  <!-- 02 dp — панели -->
        <SolidColorBrush x:Key="ObsidianCard"          Color="#1D2129"/>  <!-- 04 dp — карточки -->
        <SolidColorBrush x:Key="ObsidianRaised"        Color="#242830"/>  <!-- 06 dp — приподнятые -->
        <SolidColorBrush x:Key="ObsidianBorder"        Color="#2E333D"/>  <!-- границы -->
        <SolidColorBrush x:Key="ObsidianBorderLight"   Color="#3A4050"/>  <!-- границы при ховере -->
        <SolidColorBrush x:Key="ObsidianTextPrimary"   Color="#E2E8F0"/>  <!-- основной текст -->
        <SolidColorBrush x:Key="ObsidianTextSecondary" Color="#94A3B8"/>  <!-- вторичный текст -->
        <SolidColorBrush x:Key="ObsidianTextMuted"     Color="#64748B"/>  <!-- приглушённый -->
        <SolidColorBrush x:Key="ObsidianAccentTeal"    Color="#2DD4BF"/>  <!-- основной акцент -->
        <SolidColorBrush x:Key="ObsidianAccentBlue"    Color="#3B82F6"/>  <!-- информация -->
        <SolidColorBrush x:Key="ObsidianAccentGold"    Color="#F59E0B"/>  <!-- банк, деньги -->
        <SolidColorBrush x:Key="ObsidianAccentGreen"   Color="#22C55E"/>  <!-- верно, успех -->
        <SolidColorBrush x:Key="ObsidianAccentRed"     Color="#EF4444"/>  <!-- неверно, критический -->

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ObsidianTextPrimary}"/>
        </Style>

        <!-- ═══ OBSIDIAN TextBox ═══ -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource ObsidianSurface}"/>
            <Setter Property="Foreground" Value="{StaticResource ObsidianTextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ObsidianBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{StaticResource ObsidianTextPrimary}"/>
            <Setter Property="SelectionBrush" Value="#7C3AED"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="3" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false"
                                          HorizontalScrollBarVisibility="Hidden" 
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#5c5c5c"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4a4a4a"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Discord Scrollbar: Thumb -->
        <Style x:Key="DiscordScrollThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="thumbBorder" Background="#171B22" CornerRadius="4"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="thumbBorder" Property="Background" Value="#4e5058"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="thumbBorder" Property="Background" Value="#5e636b"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Discord Scrollbar: Vertical -->
        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinWidth" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource DiscordScrollThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="8"/>
                    <Setter Property="MinHeight" Value="8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Track x:Name="PART_Track" IsDirectionReversed="False">
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource DiscordScrollThumb}"/>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DiscordButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <!-- Overlay для hover-эффекта (осветление) -->
                                <Border x:Name="hoverOverlay" Background="White" Opacity="0" CornerRadius="4"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                  TextBlock.Foreground="{TemplateBinding Foreground}"
                                                  TextBlock.FontSize="{TemplateBinding FontSize}"
                                                  TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="hoverOverlay" Property="Opacity" Value="0.1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="hoverOverlay" Property="Opacity" Value="0.0"/>
                                <Setter TargetName="btnBorder" Property="Opacity" Value="0.75"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="btnBorder" Property="Opacity" Value="0.45"/>
                                <Setter TargetName="hoverOverlay" Property="Opacity" Value="0"/>
                                <Setter Property="Foreground" Value="#666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource ObsidianSurface}"/>
            <Setter Property="Foreground" Value="{StaticResource ObsidianTextPrimary}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" BorderBrush="{StaticResource ObsidianBorder}" BorderThickness="0,0,0,1">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#363636"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3E3E42"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource ObsidianSurface}"/>
            <Setter Property="Foreground" Value="{StaticResource ObsidianTextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ObsidianBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Grid.Column="2" Focusable="false" 
                                          IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" 
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="TkBorder" Background="{StaticResource ObsidianSurface}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                                            <Path x:Name="Arrow" Fill="#999" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Data="M0,0 L4,4 L8,0 Z"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TkBorder" Property="BorderBrush" Value="#5c5c5c"/>
                                                <Setter TargetName="Arrow" Property="Fill" Value="#CCC"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="TkBorder" Property="Background" Value="#2A2A2A"/>
                                                <Setter TargetName="TkBorder" Property="BorderBrush" Value="#5c5c5c"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ToggleButton.Background>
                                    <TemplateBinding Property="Background"/>
                                </ToggleButton.Background>
                                <ToggleButton.BorderBrush>
                                    <TemplateBinding Property="BorderBrush"/>
                                </ToggleButton.BorderBrush>
                                <ToggleButton.BorderThickness>
                                    <TemplateBinding Property="BorderThickness"/>
                                </ToggleButton.BorderThickness>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}" 
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                              Margin="10,0,25,0" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                            
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="{StaticResource ObsidianSurface}" BorderThickness="1" BorderBrush="{StaticResource ObsidianBorder}" CornerRadius="0,0,3,3" />
                                    <ScrollViewer Margin="1" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Отдельный стиль для TestRoundSelector с исправленным цветом текста -->
        <Style x:Key="TestRoundSelectorStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource ObsidianSurface}"/>
            <Setter Property="Foreground" Value="{StaticResource ObsidianTextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ObsidianBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Grid.Column="2" Focusable="false" 
                                          IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" 
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="TkBorder" Background="{StaticResource ObsidianSurface}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                                            <Path x:Name="Arrow" Fill="#999" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Data="M0,0 L4,4 L8,0 Z"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TkBorder" Property="BorderBrush" Value="#5c5c5c"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="TkBorder" Property="Background" Value="#2A2A2A"/>
                                                <Setter TargetName="TkBorder" Property="BorderBrush" Value="#5c5c5c"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ToggleButton.Background>
                                    <TemplateBinding Property="Background"/>
                                </ToggleButton.Background>
                                <ToggleButton.BorderBrush>
                                    <TemplateBinding Property="BorderBrush"/>
                                </ToggleButton.BorderBrush>
                                <ToggleButton.BorderThickness>
                                    <TemplateBinding Property="BorderThickness"/>
                                </ToggleButton.BorderThickness>
                            </ToggleButton>
                            <TextBlock x:Name="ContentSite" IsHitTestVisible="False" 
                                      Text="{TemplateBinding Text}" 
                                      Margin="10,0,25,0" 
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" 
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      Foreground="{StaticResource ObsidianTextPrimary}"/>
                            
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="{StaticResource ObsidianSurface}" BorderThickness="1" BorderBrush="{StaticResource ObsidianBorder}" CornerRadius="0,0,3,3" />
                                    <ScrollViewer Margin="1" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ObsidianSurface}"/>
            <Setter Property="Foreground" Value="{StaticResource ObsidianTextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ObsidianBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" CornerRadius="3">
                            <ContentPresenter x:Name="content" Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#363636"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#5c5c5c"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Именованный алиас для обратной совместимости -->
        <Style x:Key="NoWhiteWhenDisabledButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"/>

        <!-- ObsidianTextBox: темный ввод с тонкой рамкой -->
        <Style x:Key="ObsidianTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2b2d31"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#262626"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="#5865F2"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="3" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false"
                                          HorizontalScrollBarVisibility="Hidden" 
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#5865F2"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3a3c42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль TextBox с красной подсветкой при фокусе для редактора -->
        <Style x:Key="EditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#2b2d31"/>
            <Setter Property="Foreground" Value="{StaticResource ObsidianTextPrimary}"/>
            <Setter Property="BorderBrush" Value="#262626"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{StaticResource ObsidianTextPrimary}"/>
            <Setter Property="SelectionBrush" Value="#7C3AED"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="3" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false"
                                          HorizontalScrollBarVisibility="Hidden" 
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#da373c"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4a4a4a"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль игровых кнопок с эффектом физического нажатия -->
        <Style x:Key="GameButtonPressStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="#222" BorderThickness="0,0,0,4" Padding="{TemplateBinding Padding}" CornerRadius="5">
                            <ContentPresenter x:Name="content" Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}" HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="BorderThickness" Value="0,2,0,0"/>
                                <Setter TargetName="border" Property="Margin" Value="0,3,0,-3"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat ToggleButton (без системных рамок) -->
        <Style x:Key="FlatToggleStyle" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="tglBorder" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="10" 
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" 
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontSize="{TemplateBinding FontSize}"
                                              TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tglBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="tglBorder" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="tglBorder" Property="BorderBrush" Value="{StaticResource ObsidianAccentTeal}"/>
                                <Setter TargetName="tglBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="tglBorder" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- FlatButton: ПОЛНОЕ переопределение ControlTemplate без ButtonChrome -->
        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontSize="{TemplateBinding FontSize}"
                                              TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.65"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Dark Menu: корневое меню ═══ -->
        <Style TargetType="Menu">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#dbdee1"/>
        </Style>

        <!-- ═══ Dark MenuItem: полный шаблон ═══ -->
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <!-- Корневой бордер элемента -->
                            <Border x:Name="Border" 
                                    Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="MenuItemIconColumnGroup"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="MenuItemIGTColumnGroup"/>
                                        <ColumnDefinition Width="14"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Иконка / чекмарк -->
                                    <ContentPresenter x:Name="Icon" Grid.Column="0" 
                                                      ContentSource="Icon" 
                                                      VerticalAlignment="Center" Margin="0,0,6,0"
                                                      Width="16" Height="16"/>

                                    <!-- Текст -->
                                    <ContentPresenter Grid.Column="1" ContentSource="Header" 
                                                      RecognizesAccessKey="True" 
                                                      VerticalAlignment="Center"
                                                      TextBlock.Foreground="{TemplateBinding Foreground}"/>

                                    <!-- Горячие клавиши -->
                                    <TextBlock x:Name="IGTHost" Grid.Column="2" 
                                               Text="{TemplateBinding InputGestureText}" 
                                               Foreground="#94A3B8" FontSize="11"
                                               Margin="20,0,0,0" VerticalAlignment="Center"/>

                                    <!-- Стрелка подменю -->
                                    <Path x:Name="SubMenuArrow" Grid.Column="3" 
                                          Fill="#888" VerticalAlignment="Center" 
                                          Data="M0,0 L4,3.5 L0,7 Z" Visibility="Collapsed"/>
                                </Grid>
                            </Border>

                            <!-- Выпадающее подменю (popup) -->
                            <Popup x:Name="PART_Popup" 
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}" 
                                   Placement="Bottom" AllowsTransparency="True" Focusable="False" 
                                   PopupAnimation="Fade" HorizontalOffset="-2">
                                <Border Background="#1D2129" BorderBrush="#555" BorderThickness="1" 
                                        CornerRadius="2" Padding="0,4" SnapsToDevicePixels="True">
                                    <ScrollViewer CanContentScroll="True" 
                                                  VerticalScrollBarVisibility="Auto"
                                                  Style="{DynamicResource {ComponentResourceKey ResourceId=MenuScrollViewer, TypeInTargetAssembly={x:Type FrameworkElement}}}">
                                        <StackPanel IsItemsHost="True" 
                                                    KeyboardNavigation.DirectionalNavigation="Cycle"
                                                    Grid.IsSharedSizeScope="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- Подменю: стрелка видна -->
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="SubMenuArrow" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Right"/>
                            </Trigger>
                            <!-- Элемент подменю (без вложенных) -->
                            <Trigger Property="Role" Value="SubmenuItem">
                                <Setter TargetName="SubMenuArrow" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <!-- Hover -->
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3E3E42"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <!-- Нажатие (открытие подменю из TopLevel) -->
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#333337"/>
                            </Trigger>
                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#666"/>
                            </Trigger>
                            <!-- Скрыть иконку если нет -->
                            <Trigger Property="Icon" Value="{x:Null}">
                                <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Dark Separator в меню ═══ -->
        <Style TargetType="Separator">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="#444"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Background="{TemplateBinding Background}" 
                                Height="{TemplateBinding Height}" 
                                Margin="{TemplateBinding Margin}" 
                                SnapsToDevicePixels="True"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>
    
    <!-- Outer wrapper: Title bar + Content -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Custom Title Bar -->
        <Border Grid.Row="0" Background="#111318" BorderBrush="{StaticResource ObsidianBorder}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App icon + title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="⚡" FontSize="14" Foreground="#3B82F6" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Weakest Link — Operator Panel" FontSize="12" Foreground="#80848e" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Window control buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Stretch">
                    <Button x:Name="BtnTakeSelfie" Content="📸" ToolTip="Сделать скриншот (Ctrl + Q)"
                            Width="46" Background="Transparent" BorderThickness="0" 
                            Foreground="#80848e" FontSize="14" Cursor="Hand"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="BtnTakeSelfie_Click" Style="{StaticResource FlatButton}"/>
                    <Button x:Name="BtnTitleMinimize" Content="—" 
                            Width="46" Background="Transparent" BorderThickness="0" 
                            Foreground="#b5bac1" FontSize="13" Cursor="Hand"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="BtnTitleMinimize_Click" Style="{StaticResource FlatButton}"/>
                    <Button x:Name="BtnTitleMaximize" Content="◻" 
                            Width="46" Background="Transparent" BorderThickness="0" 
                            Foreground="#b5bac1" FontSize="13" Cursor="Hand"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="BtnTitleMaximize_Click" Style="{StaticResource FlatButton}"/>
                    <Button x:Name="BtnTitleClose" Content="✕" 
                            Width="46" Background="Transparent" BorderThickness="0" 
                            Foreground="#b5bac1" FontSize="13" Cursor="Hand"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="BtnTitleClose_Click" Style="{StaticResource FlatButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: App Content -->
        <Grid Grid.Row="1" x:Name="RootLayoutGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- COLUMN 0: Icon Sidebar (Icons) -->
        <Border Grid.Column="0" Background="{StaticResource ObsidianBg}" BorderBrush="{StaticResource ObsidianBorder}" BorderThickness="0,0,1,0">
            <StackPanel x:Name="LeftSidebarPanel" VerticalAlignment="Top" Margin="0,10,0,0">
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,8">
                    <TextBlock Text="БАНК" Foreground="#64748B" FontSize="9" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtCurrentBank_Side" Text="0" Foreground="Yellow" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
                <Border Height="1" Background="#2E333D" Margin="8,0"/>
                <StackPanel HorizontalAlignment="Center" Margin="0,8,0,8">
                    <TextBlock Text="ОБЩИЙ" Foreground="#64748B" FontSize="9" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtTotalBank_Side" Text="0" Foreground="#00FF00" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
                <Border Height="1" Background="#2E333D" Margin="8,0"/>
                <StackPanel HorizontalAlignment="Center" Margin="0,8,0,8">
                    <TextBlock Text="ВРЕМЯ" Foreground="#64748B" FontSize="9" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtTimer_Side" Text="00:00" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
                <Border Height="1" Background="#2E333D" Margin="8,0"/>
                <StackPanel HorizontalAlignment="Center" Margin="0,8,0,8">
                    <TextBlock Text="РАУНД" Foreground="#64748B" FontSize="9" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtRoundNumber_Side" Text="—" Foreground="Cyan" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
                <Border Height="1" Background="#2E333D" Margin="8,0"/>
                <StackPanel HorizontalAlignment="Center" Margin="0,8,0,8">
                    <TextBlock Text="ВОПРОС" Foreground="#64748B" FontSize="9" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtQuestionCount_Side" Text="0/0" Foreground="Orange" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>


        <!-- COLUMN 2: ПРАВАЯ ЧАСТЬ (Now Grid.Column="2") -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- 0: Верхнее меню (Debug) -->
                <RowDefinition Height="Auto"/> <!-- 1: Панель статуса (Банк, Таймер) -->
                <RowDefinition Height="Auto"/> <!-- 2: Статус действия (Вы сделали) -->
                <RowDefinition Height="*"/>    <!-- 3: Рабочая область (Лево, Центр, Право) -->
            </Grid.RowDefinitions>

            <!-- Парящая панель инструментов (overlay слева) -->
            <Border x:Name="ServiceSidePanel" Grid.RowSpan="4" Width="250" 
                        HorizontalAlignment="Left" VerticalAlignment="Stretch"
                        Background="{StaticResource ObsidianSurface}" 
                        BorderBrush="{StaticResource ObsidianBorder}" BorderThickness="0,0,1,0"
                        Panel.ZIndex="100" Visibility="Collapsed">
                    <DockPanel Margin="12,8">
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                            <TextBlock Text="☰ ИНСТРУМЕНТЫ" 
                                       Foreground="{StaticResource ObsidianTextMuted}" FontSize="10" FontWeight="Bold" 
                                       HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Background="Transparent" Foreground="{StaticResource ObsidianTextMuted}" 
                                    BorderThickness="0" FontSize="14" Cursor="Hand" Padding="4,0"
                                    Click="BtnCloseToolbar_Click" ToolTip="Закрыть панель">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="Transparent" CornerRadius="4" Padding="6,2">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#242830"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <!-- === ЭКРАНЫ (перенесены из правой панели) === -->
                            <TextBlock Text="ЭКРАНЫ" Foreground="{StaticResource ObsidianAccentTeal}" FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                            <UniformGrid Columns="2">
                                <Button x:Name="BtnScreenHost" Content="HOST CLASSIC" Height="26" Margin="0,0,2,3" FontSize="9"
                                        Background="#2E333D" Foreground="#E2E8F0" 
                                        BorderBrush="Transparent" BorderThickness="2"
                                        Click="BtnOpenHost_Click" Style="{StaticResource FlatButton}"/>
                                <Button x:Name="BtnScreenModern" Content="HOST MODERN" Height="26" Margin="2,0,0,3" FontSize="9"
                                        Background="#2E333D" Foreground="#E2E8F0" 
                                        BorderBrush="Transparent" BorderThickness="2"
                                        Click="BtnOpenHostModern_Click" Style="{StaticResource FlatButton}"/>
                                <Button x:Name="BtnScreenPremium" Content="PREMIUM" Height="26" Margin="0,0,2,3" FontSize="9"
                                        Background="#3B82F6" Foreground="White" 
                                        BorderBrush="Transparent" BorderThickness="2"
                                        Click="BtnOpenHostPremium_Click" Style="{StaticResource FlatButton}"/>
                                <Button x:Name="BtnScreenModPremium" Content="MOD. PREMIUM" Height="26" Margin="2,0,0,3" FontSize="9"
                                        Background="#3B82F6" Foreground="White" 
                                        BorderBrush="Transparent" BorderThickness="2"
                                        Click="BtnOpenHostModernPremium_Click" Style="{StaticResource FlatButton}"/>
                                <Button x:Name="BtnScreenBroadcast" Content="📡 BROADCAST" Height="26" Margin="0,0,2,3" FontSize="9"
                                        Background="#DC2626" Foreground="White" FontWeight="Bold"
                                        BorderBrush="Transparent" BorderThickness="2"
                                        Click="BtnOpenBroadcast_Click" Style="{StaticResource FlatButton}"/>
                                <Button x:Name="BtnScreenAudience" Content="🎭 AUDIENCE" Height="26" Margin="2,0,0,3" FontSize="9"
                                        Background="#1565C0" Foreground="White" FontWeight="Bold"
                                        BorderBrush="Transparent" BorderThickness="2"
                                        Click="BtnOpenAudience_Click" Style="{StaticResource FlatButton}"/>
                            </UniformGrid>
                            <Button Content="ANALYTICS" Height="24" Margin="0,0,0,3" FontSize="9"
                                    Background="#2E333D" Foreground="#E2E8F0" 
                                    Click="BtnAnalytics_Click" Style="{StaticResource FlatButton}"/>

                            <!-- Разделитель -->
                            <Border Height="1" Background="{StaticResource ObsidianBorder}" Margin="0,4,0,6"/>

                            <!-- === ИНСТРУМЕНТЫ === -->
                            <Button Content="✎ РЕДАКТОР ВОПРОСОВ" x:Name="BtnToggleQuestionEditor" Height="32" Margin="0,0,0,3" 
                                    Click="BtnToggleQuestionEditor_Click" Style="{StaticResource FlatButton}"
                                    Background="#1D2129" Foreground="{StaticResource ObsidianTextPrimary}" 
                                    BorderBrush="#2E333D" BorderThickness="1" FontSize="11" FontWeight="Bold"/>
                            <Button Content="📊 АНАЛИТИКА" x:Name="BtnToggleAnalytics" Height="32" Margin="0,0,0,3" 
                                    Click="BtnToggleAnalytics_Click" Style="{StaticResource FlatButton}"
                                    Background="#1D2129" Foreground="{StaticResource ObsidianTextPrimary}" 
                                    BorderBrush="#2E333D" BorderThickness="1" FontSize="11" FontWeight="Bold"/>
                            <Button Content="✓ VALIDATE JSON" x:Name="BtnValidateJson" Height="32" Margin="0,0,0,3" 
                                    Click="BtnValidateJson_Click" Style="{StaticResource FlatButton}"
                                    Background="#1D2129" Foreground="{StaticResource ObsidianTextPrimary}" 
                                    BorderBrush="#2E333D" BorderThickness="1" FontSize="11" FontWeight="Bold"/>
                            <Button Content="🧪 SELF-TEST" x:Name="BtnSelfTest" Height="32" Margin="0,0,0,3" 
                                    Click="BtnSelfTest_Click" Style="{StaticResource FlatButton}"
                                    Background="#1D2129" Foreground="#FF9800" 
                                    BorderBrush="#2E333D" BorderThickness="1" FontSize="11" FontWeight="Bold"/>

                            <!-- Разделитель -->
                            <Border Height="1" Background="{StaticResource ObsidianBorder}" Margin="0,6,0,6"/>

                            <!-- === DEBUG СЕКЦИЯ === -->
                            <TextBlock Text="DEBUG" Foreground="{StaticResource ObsidianAccentTeal}" FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="Раунд теста:" Foreground="#94A3B8" FontSize="10" Margin="0,0,0,3"/>
                            <ComboBox x:Name="TestRoundSelector" Height="25" FontSize="11" SelectedIndex="0" Style="{StaticResource TestRoundSelectorStyle}" VerticalContentAlignment="Center" Margin="0,0,0,4">
                                <ComboBoxItem Content="Раунд 1"/>
                                <ComboBoxItem Content="Раунд 2"/>
                                <ComboBoxItem Content="Раунд 3"/>
                                <ComboBoxItem Content="Раунд 4"/>
                                <ComboBoxItem Content="Раунд 5"/>
                                <ComboBoxItem Content="Раунд 6"/>
                                <ComboBoxItem Content="Раунд 7"/>
                                <ComboBoxItem Content="ФИНАЛ"/>
                            </ComboBox>
                            <CheckBox x:Name="ChkTestLast30Sec" Content="30 сек раунд" Foreground="#94A3B8" FontSize="10" Margin="0,3,0,0"/>
                            <CheckBox x:Name="ChkDebugEndRoundButton" Content="кнопка Раунд Завершен" Foreground="#94A3B8" FontSize="10" Margin="0,3,0,4" Click="ChkDebugEndRoundButton_Click"/>
                            <Button Content="БЫСТРЫЙ СТАРТ" x:Name="BtnQuickStart" Height="26" FontSize="10" 
                                    Background="#3B82F6" Foreground="White" Margin="0,0,0,3" Padding="8,0" 
                                    Click="BtnQuickStart_Click" Style="{StaticResource FlatButton}"/>
                            <Button Content="ЗАПОЛНИТЬ СЛУЧАЙНЫМИ" x:Name="BtnFillRandom" Height="26" FontSize="10" 
                                    Background="#2E333D" Foreground="White" Margin="0,0,0,3" Padding="8,0" 
                                    Click="BtnFillRandom_Click" Style="{StaticResource FlatButton}"/>
                            <Button Content="🎬 ТЕСТ ФИНАЛА" x:Name="BtnDebugTestFinal" Height="26" FontSize="10" 
                                    Background="#EF4444" Foreground="White" Margin="0,0,0,3" Padding="8,0" 
                                    Click="BtnDebugTestFinal_Click" Style="{StaticResource FlatButton}"/>
                            
                            <!-- === ТЕСТОВАЯ ИГРА === -->
                            <Border Height="1" Background="{StaticResource ObsidianBorder}" Margin="0,6,0,6"/>
                            <TextBlock Text="ТЕСТОВАЯ ИГРА" Foreground="{StaticResource ObsidianTextMuted}" FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                            <Button Content="Загрузить команду..." Height="26" FontSize="10" Margin="0,0,0,3"
                                    Background="#1D2129" Foreground="{StaticResource ObsidianTextPrimary}" 
                                    BorderBrush="#2E333D" BorderThickness="1"
                                    Click="BtnTestTeam1_Click" Style="{StaticResource FlatButton}"/>
                            <Button Content="AI Gemini Test" Height="26" FontSize="10" Margin="0,0,0,3"
                                    Background="#1D2129" Foreground="{StaticResource ObsidianTextPrimary}" 
                                    BorderBrush="#2E333D" BorderThickness="1"
                                    Click="BtnStartGeminiTest_Click" Style="{StaticResource FlatButton}"/>

                            <!-- === СЕРВИС === -->
                            <Border Height="1" Background="{StaticResource ObsidianBorder}" Margin="0,6,0,6"/>
                            <TextBlock Text="СЕРВИС" Foreground="{StaticResource ObsidianTextMuted}" FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                            <Button x:Name="BtnStopAudio" Height="32" Margin="0,0,0,3" Click="BtnStopAudio_Click" Style="{StaticResource FlatButton}"
                                    Background="{StaticResource ObsidianSurface}" Foreground="{StaticResource ObsidianTextPrimary}" 
                                    BorderBrush="{StaticResource ObsidianBorder}" BorderThickness="1" FontWeight="Bold" FontSize="11"
                                    HorizontalContentAlignment="Center">
                                <TextBlock Text="🔇 STOP AUDIO" TextAlignment="Center"/>
                            </Button>
                            <Button x:Name="BtnRestartRound" Height="32" Margin="0,0,0,3" Click="BtnRestartRound_Click" Style="{StaticResource FlatButton}"
                                    Background="#5B1A1A" Foreground="#FF9999" 
                                    BorderBrush="#7B3333" BorderThickness="1" FontWeight="Bold" FontSize="11"
                                    HorizontalContentAlignment="Center">
                                <TextBlock Text="🔄 RESTART ROUND" TextAlignment="Center"/>
                            </Button>
                            <Button x:Name="BtnCloseSession" Height="32" Margin="0,0,0,3" Click="BtnCloseSession_Click" Style="{StaticResource FlatButton}"
                                    Background="{StaticResource ObsidianSurface}" Foreground="{StaticResource ObsidianTextPrimary}" 
                                    BorderBrush="{StaticResource ObsidianBorder}" BorderThickness="1" FontWeight="Bold" FontSize="11"
                                    HorizontalContentAlignment="Center">
                                <TextBlock Text="🚪 CLOSE SESSION" TextAlignment="Center"/>
                            </Button>
                            <Border Height="1" Background="{StaticResource ObsidianBorder}" Margin="0,6,0,6"/>
                            <Button x:Name="BtnBreakGame" Height="36" Click="BtnBreakGame_Click" Style="{StaticResource FlatButton}"
                                    Background="#991B1B" Foreground="White" 
                                    BorderBrush="#AA3333" BorderThickness="1" FontWeight="Black" FontSize="11"
                                    HorizontalContentAlignment="Center">
                                <TextBlock Text="⚠ BREAK GAME" TextAlignment="Center"/>
                            </Button>
                        </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>


            <!-- 0. ВЕРХНЯЯ ШАПКА (Минималистичная) -->
            <Border Grid.Row="0" Background="{StaticResource ObsidianSurface}" Height="38" BorderBrush="{StaticResource ObsidianBorder}" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,4">
                        <ToggleButton x:Name="TglServicePanel" ToolTip="Панель инструментов"
                                      Background="Transparent" BorderThickness="0" Cursor="Hand"
                                      VerticalAlignment="Center" Margin="0,0,10,0"
                                      IsChecked="False" Checked="TglServicePanel_Changed" Unchecked="TglServicePanel_Changed">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="bd" Background="Transparent" CornerRadius="6" Padding="8,4">
                                        <TextBlock x:Name="ico" Text="☰" FontSize="16" Foreground="{StaticResource ObsidianTextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#242830"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="{StaticResource ObsidianTextPrimary}"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{StaticResource ObsidianBorder}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="{StaticResource ObsidianAccentTeal}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <TextBlock Text="WEAKEST LINK" Foreground="{StaticResource ObsidianTextPrimary}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <Border x:Name="TestModeBadge" Background="#331a00" BorderBrush="#FF9800" BorderThickness="1" CornerRadius="6" Padding="10,4" Visibility="Collapsed">
                            <TextBlock x:Name="TxtTestModeLabel" Text="ТЕСТ: —" Foreground="#FF9800" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Menu VerticalAlignment="Center" Background="Transparent" BorderThickness="0">
                            <MenuItem Foreground="#94A3B8" FontSize="12" StaysOpenOnClick="True">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="QR" VerticalAlignment="Center"/>
                                        <Image x:Name="QrCodeImage" Width="20" Height="20" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                        </Menu>
                    </StackPanel>
                </Grid>
            </Border>

<!-- 1. FUTURIST TIMER HUB (Sketched Semi-Circle & Wings) -->
            <Grid Grid.Row="1" Margin="10,5,10,10" ClipToBounds="False">
                <Grid.Resources>
                    <Storyboard x:Key="TimerHubPulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
                        <DoubleAnimation Storyboard.TargetName="TimerArchBorder"
                                         Storyboard.TargetProperty="Opacity"
                                         From="1.0" To="0.55" Duration="0:0:0.6"/>
                    </Storyboard>
                </Grid.Resources>

                <!-- 1A: STATS BAR (Monolithic) -->
                <Border Background="#1D2129" CornerRadius="10" BorderBrush="#2E333D" BorderThickness="1" 
                        Height="52" VerticalAlignment="Bottom">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Col 0: ТЕКУЩИЙ БАНК -->
