<Window x:Class="WeakestLink.Views.BroadcastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Broadcast" Background="Black"
        Width="1920" Height="1080"
        WindowStyle="None" ResizeMode="NoResize"
        WindowState="Maximized"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <Style x:Key="ChainAmountStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Arial Black"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="2" Opacity="0.9"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- ЛЕВАЯ КОЛОНКА: цепочка -->
        <Canvas x:Name="ChainCanvas"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Width="310"
                ClipToBounds="False"/>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- ФИНАЛЬНАЯ ДУЭЛЬ: оверлей как в эфире Первого канала -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid x:Name="FinalDuelOverlay" Visibility="Collapsed"
              HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,80">
            <StackPanel>
                <!-- Игрок 1: плашка имени + 5 бейджей -->
                <StackPanel Orientation="Horizontal" Margin="0,6" HorizontalAlignment="Center">
                    <!-- Плашка имени -->
                    <Grid Width="220" Height="60" Margin="0,0,20,0">
                        <Image x:Name="ImgNameplate1" Stretch="Fill"/>
                        <TextBlock x:Name="TxtFinalPlayer1" Text=""
                                   FontFamily="Arial Black" FontSize="22" FontWeight="ExtraBold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.8"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Grid>
                    <!-- Бейджи -->
                    <StackPanel x:Name="FinalRow1" Orientation="Horizontal" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Игрок 2: плашка имени + 5 бейджей -->
                <StackPanel Orientation="Horizontal" Margin="0,6" HorizontalAlignment="Center">
                    <!-- Плашка имени -->
                    <Grid Width="220" Height="60" Margin="0,0,20,0">
                        <Image x:Name="ImgNameplate2" Stretch="Fill"/>
                        <TextBlock x:Name="TxtFinalPlayer2" Text=""
                                   FontFamily="Arial Black" FontSize="22" FontWeight="ExtraBold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.8"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Grid>
                    <!-- Бейджи -->
                    <StackPanel x:Name="FinalRow2" Orientation="Horizontal" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Внезапная смерть -->
                <TextBlock x:Name="TxtSuddenDeath" Text="" FontFamily="Arial Black" FontSize="24"
                           FontWeight="ExtraBold" Foreground="#FF4444"
                           HorizontalAlignment="Center" Margin="0,12,0,0"
                           Visibility="Collapsed">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#FF0000" BlurRadius="12" ShadowDepth="0" Opacity="0.7"/>
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- ОВЕРЛЕЙ: ОБЩИЙ БАНК -->
        <Grid x:Name="BankOverlay" Visibility="Collapsed"
              HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,80">
            <Image x:Name="ImgBankOverlay" Stretch="Fill" Width="700" Height="200"/>
            <TextBlock x:Name="TxtBankOverlayAmount" Text="0"
                       FontFamily="Arial Black" FontSize="56" FontWeight="ExtraBold"
                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Margin="0,-16,0,0">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="2" Opacity="0.8"/>
                </TextBlock.Effect>
            </TextBlock>
        </Grid>

        <!-- ЦЕНТРАЛЬНАЯ ИНФОРМАЦИОННАЯ ПАНЕЛЬ (F10) -->
        <Grid x:Name="InfoPanel" Visibility="Collapsed" Margin="240,0,220,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#80000000" CornerRadius="0,0,16,16"
                    HorizontalAlignment="Center" Padding="30,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="TxtRoundInfo" Text="" FontFamily="Arial Black" FontSize="40"
                               FontWeight="ExtraBold" Foreground="#FFD700">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="2" Opacity="0.8"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock x:Name="TxtBankInfo" Text="" FontFamily="Arial Black" FontSize="40"
                               FontWeight="ExtraBold" Foreground="#00FF88" Margin="40,0,0,0">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="2" Opacity="0.8"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>
            </Border>
            <Border x:Name="QuestionBorder" Grid.Row="1" Background="#60000000" CornerRadius="12"
                    Margin="30" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center"
                    MaxWidth="1100" Visibility="Collapsed">
                <TextBlock x:Name="TxtQuestion" Text="" FontFamily="Arial" FontSize="38" FontWeight="Bold"
                           Foreground="White" TextWrapping="Wrap" TextAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="3" Opacity="0.9"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Border>
            <Border Grid.Row="2" Background="#80000000" CornerRadius="16,16,0,0"
                    HorizontalAlignment="Center" Padding="30,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ХОД ИГРОКА  " FontFamily="Arial" FontSize="22"
                               Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtCurrentPlayer" Text="" FontFamily="Arial Black" FontSize="30"
                               FontWeight="ExtraBold" Foreground="#00FFFF">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#0088FF" BlurRadius="12" ShadowDepth="0" Opacity="0.6"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ПРАВЫЙ НИЗ: таймер — TIMER.png как фон -->
        <Grid x:Name="TimerBorder"
              HorizontalAlignment="Right" VerticalAlignment="Bottom"
              Margin="0,0,30,30" Width="250" Height="130">
            <Grid.Effect>
                <DropShadowEffect Color="#0066cc" BlurRadius="16" ShadowDepth="0" Opacity="0.6"/>
            </Grid.Effect>
            <Image x:Name="ImgTimerBg" Stretch="Fill"/>
            <!-- Текст по центру — точно как на плашках цепочки -->
            <TextBlock x:Name="TxtTimer" Text="2:30"
                       FontFamily="Arial Black" FontSize="26" FontWeight="ExtraBold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="2" Opacity="0.9"/>
                </TextBlock.Effect>
            </TextBlock>
        </Grid>

        <!-- ОВЕРЛЕЙ: Логотип -->
        <Grid x:Name="LogoOverlay" Visibility="Collapsed" Background="Black">
            <Image x:Name="ImgLogo" Stretch="Uniform"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   MaxWidth="1400" MaxHeight="900"/>
        </Grid>

        <!-- ОВЕРЛЕЙ: Выбывание -->
        <Grid x:Name="EliminationOverlay" Visibility="Collapsed">
            <Grid.Background>
                <SolidColorBrush Color="Black" Opacity="0.75"/>
            </Grid.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="СЛАБОЕ ЗВЕНО:" FontFamily="Arial Black" FontSize="64"
                           Foreground="#888" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtEliminatedName" Text=""
                           FontFamily="Arial Black" FontSize="120"
                           Foreground="White" FontWeight="ExtraBold" HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#da373c" BlurRadius="30" ShadowDepth="0" Opacity="1"/>
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- ОВЕРЛЕЙ: Статус -->
        <Grid x:Name="StatusOverlay" Visibility="Collapsed">
            <Grid.Background>
                <SolidColorBrush Color="Black" Opacity="0.6"/>
            </Grid.Background>
            <TextBlock x:Name="TxtStatus" Text=""
                       FontFamily="Arial Black" FontSize="96"
                       Foreground="White" FontWeight="ExtraBold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#0044aa" BlurRadius="40" ShadowDepth="0" Opacity="0.9"/>
                </TextBlock.Effect>
            </TextBlock>
        </Grid>
    </Grid>
</Window>
