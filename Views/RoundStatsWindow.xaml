<Window x:Class="WeakestLink.Views.RoundStatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Аналитика раунда - Слабое звено" Height="800" Width="1200"
        Background="#0A0A15" Foreground="White"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">
    
    <Window.Resources>
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        
        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="BorderBrush" Value="#333366"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="10"/>
        </Style>
        
        <Style x:Key="PredictionTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FF4444"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="2" Color="#FF0000" Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="📊 АНАЛИТИКА РАУНДА" 
                   FontSize="32" FontWeight="Bold" 
                   Foreground="#FFD700" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,20"/>
        
        <!-- Прогноз выбывания -->
        <Border Grid.Row="1" Style="{StaticResource SectionBorderStyle}" 
                Background="#2A1A1A" BorderBrush="#FF4444">
            <StackPanel>
                <TextBlock Text="⚠️ ПРОГНОЗ НА ВЫБЫТИЕ" 
                           Style="{StaticResource HeaderTextStyle}" 
                           Foreground="#FF6666"/>
                <TextBlock x:Name="PredictionText" 
                           Text="Прогноз на выбывание: Ожидание данных..."
                           Style="{StaticResource PredictionTextStyle}"/>
                <TextBlock x:Name="ExplanationText" Text="" 
                           FontSize="12" 
                           Foreground="#AAAAAA" 
                           TextAlignment="Center" 
                           FontStyle="Italic"
                           Margin="0,5"
                           Visibility="Collapsed"/>
                <!-- Плашка ничьей -->
                <Border x:Name="TieBanner" Background="#FFD700" CornerRadius="5" Padding="10,6" Margin="0,8,0,0" Visibility="Collapsed">
                    <TextBlock x:Name="TieBannerText" Text="" FontSize="18" FontWeight="Bold" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>
        
        <!-- Основная статистика -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Статистика игроков -->
            <Border Grid.Column="0" Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <TextBlock Text="👥 СТАТИСТИКА ИГРОКОВ" Style="{StaticResource HeaderTextStyle}"/>
                    <TextBlock Text="Игроки без ответов в раунде: --- (не участвовали)" 
                               FontSize="11" Foreground="#888" 
                               FontStyle="Italic" 
                               Margin="0,0,0,10"/>
                    
                    <DataGrid x:Name="PlayersDataGrid" 
                              AutoGenerateColumns="False" 
                              CanUserAddRows="False" 
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              CanUserSortColumns="True"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#333366"
                              VerticalGridLinesBrush="Transparent"
                              Background="Transparent"
                              Foreground="White"
                              FontSize="14"
                              MaxHeight="400">
                        
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#2A2A4A"/>
                                <Setter Property="Foreground" Value="#FFD700"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="Height" Value="35"/>
                                <Setter Property="FontSize" Value="13"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#1A1A2E"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2A2A4A"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#3A3A6A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Имя игрока" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Верно" Binding="{Binding CorrectAnswers}" Width="60" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#00FF00"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Неверно" Binding="{Binding IncorrectAnswers}" Width="70" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#FF6666"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Пасы" Binding="{Binding Passes}" Width="60" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#FFAA00"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Ошибки" Binding="{Binding TotalMistakes}" Width="60" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#FF4444"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="В банк" Binding="{Binding BankedMoney, StringFormat={}{0:N0} ₽}" Width="90" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Foreground" Value="#00DDFF"/>
                                        <Setter Property="Margin" Value="0,0,10,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Средний банк" Width="95" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Foreground" Value="#FF88CC"/>
                                        <Setter Property="Margin" Value="0,0,10,0"/>
                                        <Setter Property="Text" Value="{Binding AverageBankAmount, StringFormat={}{0:N0} ₽}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BankPressCount}" Value="0">
                                                <Setter Property="Text" Value="---"/>
                                                <Setter Property="Foreground" Value="#888888"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Успешность" Width="80" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#FFD700"/>
                                        <Setter Property="Text" Value="{Binding SuccessPercentage, StringFormat={}{0:F1}%}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TotalQuestions}" Value="0">
                                                <Setter Property="Text" Value="---"/>
                                                <Setter Property="Foreground" Value="#888888"/>
                                                <Setter Property="FontStyle" Value="Italic"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
            
            <!-- Статистика раунда -->
            <Border Grid.Column="1" Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <TextBlock Text="📈 СТАТИСТИКА РАУНДА" Style="{StaticResource HeaderTextStyle}"/>
                    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Собрано в банк:" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TotalBankedText" Text="0 ₽" 
                                   Foreground="#00FF00" FontWeight="Bold" VerticalAlignment="Center" Margin="10,5"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Сгорело денег:" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TotalBurnedText" Text="0 ₽" 
                                   Foreground="#FF6666" FontWeight="Bold" VerticalAlignment="Center" Margin="10,5"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Длительность раунда:" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="RoundDurationText" Text="0:00" 
                                   Foreground="#FFFFFF" FontWeight="Bold" VerticalAlignment="Center" Margin="10,5"/>
                        
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Всего вопросов:" VerticalAlignment="Center" Margin="0,5" ToolTip="Сумма ответов всех игроков за раунд"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TotalQuestionsText" Text="0" 
                                   Foreground="#FFFFFF" FontWeight="Bold" VerticalAlignment="Center" Margin="10,5"/>
                        
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Среднее время ответа:" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="AverageTimeText" Text="0.0 сек" 
                                   Foreground="#FFAA00" FontWeight="Bold" VerticalAlignment="Center" Margin="10,5"/>
                        
                        <Separator Grid.Row="5" Grid.ColumnSpan="2" Margin="0,15" Background="#333366"/>
                        
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Сильное звено:" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" x:Name="StrongestLinkText" Text="—" 
                                   Foreground="#00FF00" FontWeight="Bold" VerticalAlignment="Center" Margin="10,5"/>
                        
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Слабое звено:" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" x:Name="WeakestLinkText" Text="—" 
                                   Foreground="#FF6666" FontWeight="Bold" VerticalAlignment="Center" Margin="10,5"/>
                        
                        <TextBlock Grid.Row="8" Grid.Column="0" Text="🛡️ Главный перестраховщик:" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBlock Grid.Row="8" Grid.Column="1" x:Name="PanicBankerText" Text="—" 
                                   Foreground="#FF88CC" FontWeight="Bold" VerticalAlignment="Center" Margin="10,5"/>
                        
                        <TextBlock Grid.Row="9" Grid.Column="0" Text="Эффективность:" VerticalAlignment="Center" Margin="0,5"
                                   ToolTip="Доля сохранённого в банк от общего оборота (собрано + сгорело)"/>
                        <TextBlock Grid.Row="9" Grid.Column="1" x:Name="EfficiencyText" Text="0%" 
                                   Foreground="#FFD700" FontWeight="Bold" VerticalAlignment="Center" Margin="10,5"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Кнопки внизу -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="📥 ЭКСПОРТ В CSV" 
                    x:Name="BtnExportCsv"
                    Background="#1565C0" Foreground="White" 
                    FontSize="16" FontWeight="Bold" 
                    Height="50" Width="220" 
                    Margin="0,0,20,0"
                    BorderThickness="0"
                    Click="BtnExportCsv_Click"
                    Cursor="Hand"
                    ToolTip="Выгрузить статистику раунда в CSV для Excel">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                        VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="ЗАКРЫТЬ АНАЛИТИКУ" 
                Background="#C10000" Foreground="White" 
                FontSize="16" FontWeight="Bold" 
                Height="50" Width="200" 
                BorderThickness="0"
                Click="CloseButton_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="8" 
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        BorderBrush="{TemplateBinding BorderBrush}">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                                    VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FF0000"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
        </StackPanel>
    </Grid>
</Window>
