<Window x:Class="WeakestLink.Views.RoundStatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Round Analytics [Mission Control]" Height="700" Width="1000"
        Background="#0D0D0D" Foreground="#E0E0E0"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanMinimize">
        
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="0" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Flat, dark themes matching Obsidian -->
        <Style x:Key="SurfaceCard" TargetType="Border">
            <Setter Property="Background" Value="#161616"/>
            <Setter Property="BorderBrush" Value="#262626"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
        </Style>

        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background" Value="#161616"/>
            <Setter Property="BorderBrush" Value="#262626"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="MinWidth" Value="150"/>
        </Style>
        
        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Background" Value="#262626"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RedButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="Background" Value="#da373c"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#ff4f54"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#808080"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="45"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#262626"/>
                    <Setter Property="Foreground" Value="#E0E0E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WindowCloseButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#da373c"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#262626" BorderThickness="1" Background="#0D0D0D">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0" Background="#161616" BorderBrush="#262626" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="ROUND ANALYTICS [MISSION CONTROL]" 
                               Foreground="#808080" FontSize="11" FontWeight="SemiBold" 
                               VerticalAlignment="Center" Margin="15,0" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="—" Style="{StaticResource WindowControlButton}" Click="BtnMinimize_Click"/>
                        <Button Content="✕" Style="{StaticResource WindowCloseButton}" Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

        <!-- TOP: Prediction Card -->
        <Border Grid.Row="0" Style="{StaticResource SurfaceCard}" BorderBrush="#da373c">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="ELIMINATION PREDICTOR" FontSize="11" Foreground="#808080" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock x:Name="PredictionText" Text="Прогноз: Ожидание..." FontSize="28" FontWeight="Bold" Foreground="#da373c" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ExplanationText" Text="Обоснование решения" FontSize="13" Foreground="#808080" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                
                <Border x:Name="TieBanner" Background="#da373c" CornerRadius="4" Padding="10,4" Margin="0,10,0,0" Visibility="Collapsed">
                    <TextBlock x:Name="TieBannerText" Text="НИЧЬЯ" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- CENTER: DataGrid -->
        <Border Grid.Row="1" Style="{StaticResource SurfaceCard}" Padding="5">
            <DataGrid x:Name="PlayersDataGrid" 
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False" 
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserSortColumns="True"
                      GridLinesVisibility="None"
                      Background="Transparent"
                      BorderThickness="0"
                      RowBackground="Transparent"
                      RowHeaderWidth="0"
                      Foreground="#E0E0E0"
                      FontSize="14"
                      LoadingRow="GridPlayerStats_LoadingRow">
                
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#808080"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="Height" Value="35"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Padding" Value="5,0"/>
                        <!-- Caps-like text appearance for header -->
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#262626"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#262626"/>
                        <Setter Property="Margin" Value="0,2"/>
                        <Setter Property="Padding" Value="0,5"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#222222"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ИМЯ" Binding="{Binding Name}" Width="*" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="10,0"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="ВЕРНО" Binding="{Binding CorrectAnswers}" Width="80" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="ОШИБКИ" Binding="{Binding TotalMistakes}" Width="80" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="#da373c"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="В БАНК" Binding="{Binding BankedMoney, StringFormat={}{0:N0} ₽}" Width="100" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="#00DDFF"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="СРЕД. БАНК" Width="100" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="#7a2ad1"/>
                                <Setter Property="Text" Value="{Binding AverageBankAmount, StringFormat={}{0:N0} ₽}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BankPressCount}" Value="0">
                                        <Setter Property="Text" Value="—"/>
                                        <Setter Property="Foreground" Value="#404040"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="%" Width="80" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="#808080"/>
                                <Setter Property="Text" Value="{Binding SuccessPercentage, StringFormat={}{0:F1}%}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TotalQuestions}" Value="0">
                                        <Setter Property="Text" Value="—"/>
                                        <Setter Property="FontStyle" Value="Italic"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- BOTTOM: Metric Cards -->
        <WrapPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
            <Border Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="В БАНК" FontSize="11" Foreground="#808080"/>
                    <TextBlock x:Name="TotalBankedText" Text="0 ₽" FontSize="20" FontWeight="Bold" Foreground="#00DDFF" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="СГОРЕЛО" FontSize="11" Foreground="#808080"/>
                    <TextBlock x:Name="TotalBurnedText" Text="0 ₽" FontSize="20" FontWeight="Bold" Foreground="#da373c" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="ЭФФЕКТИВНОСТЬ" FontSize="11" Foreground="#808080"/>
                    <TextBlock x:Name="EfficiencyText" Text="0%" FontSize="20" FontWeight="Bold" Foreground="#FFD700" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="СИЛЬНОЕ ЗВЕНО" FontSize="11" Foreground="#808080"/>
                    <TextBlock x:Name="StrongestLinkText" Text="—" FontSize="20" FontWeight="Bold" Foreground="#00FF00" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="PANIC BANKER" FontSize="11" Foreground="#808080"/>
                    <TextBlock x:Name="PanicBankerText" Text="—" FontSize="18" FontWeight="Bold" Foreground="#7a2ad1" Margin="0,5,0,0" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Content="ЭКСПОРТ CSV" Style="{StaticResource FlatButton}" Width="150" Margin="0,0,10,0" Click="BtnExportCsv_Click"/>
            <Button Content="ЗАКРЫТЬ" Style="{StaticResource RedButton}" Width="150" Click="BtnClose_Click"/>
        </StackPanel>

            </Grid>
        </Grid>
    </Border>
</Window>
