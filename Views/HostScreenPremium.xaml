<Window x:Class="WeakestLink.Views.HostScreenPremium"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Weakest Link - Host Screen (Premium)" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        Background="Black"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- Анимация появления вопроса -->
        <Storyboard x:Key="QuestionEntrance">
            <DoubleAnimation Storyboard.TargetName="QuestionTransform" 
                             Storyboard.TargetProperty="Y"
                             From="15" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="TxtQuestion" 
                             Storyboard.TargetProperty="Opacity"
                             From="0.7" To="1" Duration="0:0:0.25"/>
        </Storyboard>

        <!-- Анимация появления ответа -->
        <Storyboard x:Key="AnswerEntrance">
            <DoubleAnimation Storyboard.TargetName="AnswerTransform" 
                             Storyboard.TargetProperty="Y"
                             From="8" To="0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="AnswerBorder" 
                             Storyboard.TargetProperty="Opacity"
                             From="0.7" To="1" Duration="0:0:0.2"/>
        </Storyboard>
    </Window.Resources>
    
    <Viewbox Stretch="Uniform">
        <Viewbox.ContextMenu>
            <ContextMenu>
                <MenuItem Header="ВКЛ/ВЫКЛ РАМКУ (CHROME)" Click="ToggleChrome_Click"/>
                <MenuItem Header="ЗАКРЫТЬ" Click="Close_Click"/>
            </ContextMenu>
        </Viewbox.ContextMenu>
        <Grid x:Name="RootGrid" Width="1920" Height="1080">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#020410" Offset="0"/>
                    <GradientStop Color="#050A30" Offset="0.5"/>
                    <GradientStop Color="#020410" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="MoneyTreeColumn" Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ЛЕВАЯ КОЛОНКА: ДЕНЕЖНОЕ ДЕРЕВО -->
            <Border x:Name="MoneyTreeBorder" Grid.Column="0" Background="#99020208" BorderBrush="#222" BorderThickness="0,0,1,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="Black" Opacity="0.5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="ЦЕПОЧКА" FontSize="18" FontWeight="SemiBold" Foreground="#444" 
                               HorizontalAlignment="Center" Margin="0,20,0,10"/>

                    <ItemsControl Grid.Row="1" x:Name="HostBankChainList" VerticalAlignment="Stretch">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid x:Name="HostChainGrid" Width="180" Height="82" VerticalAlignment="Center" Margin="0,3">
                                    <Ellipse x:Name="BgEllipse" StrokeThickness="1.5">
                                        <Ellipse.Fill>
                                            <RadialGradientBrush Center="0.5,0.3" GradientOrigin="0.5,0.3" RadiusX="0.7" RadiusY="0.5">
                                                <GradientStop Color="#1A2A4A" Offset="0"/>
                                                <GradientStop Color="#000818" Offset="1"/>
                                            </RadialGradientBrush>
                                        </Ellipse.Fill>
                                        <Ellipse.Stroke>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#444" Offset="0"/>
                                                <GradientStop Color="#222" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Ellipse.Stroke>
                                    </Ellipse>
                                    
                                    <!-- Блик для 3D эффекта -->
                                    <Ellipse Margin="15,6,15,0" Height="22" VerticalAlignment="Top" Opacity="0.12">
                                        <Ellipse.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="White" Offset="0"/>
                                                <GradientStop Color="Transparent" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <TextBlock x:Name="HostChainText" 
                                               Text="{Binding Value, StringFormat={}{0:N0}}" 
                                               FontSize="30" FontWeight="ExtraBold" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="#666">
                                        <TextBlock.Effect>
                                            <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.5"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter TargetName="BgEllipse" Property="Fill">
                                            <Setter.Value>
                                                <RadialGradientBrush Center="0.5,0.3" GradientOrigin="0.5,0.3" RadiusX="0.8" RadiusY="0.6">
                                                    <GradientStop Color="#FF4D4D" Offset="0"/>
                                                    <GradientStop Color="#B30000" Offset="0.8"/>
                                                    <GradientStop Color="#660000" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter TargetName="BgEllipse" Property="Stroke" Value="White"/>
                                        <Setter TargetName="BgEllipse" Property="StrokeThickness" Value="2"/>
                                        <Setter TargetName="HostChainText" Property="Foreground" Value="White"/>
                                        <Setter TargetName="HostChainText" Property="FontSize" Value="34"/>
                                        <Setter TargetName="HostChainGrid" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="35" ShadowDepth="0" Color="#FF0000" Opacity="0.8"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <StackPanel Grid.Row="2" VerticalAlignment="Top" Margin="0,10,0,40">
                        <TextBlock Text="BANK" FontSize="18" FontWeight="Black" Foreground="#555" 
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ПРАВАЯ КОЛОНКА: ИГРОВОЙ КОНТЕНТ (ТВ-СУФЛЕР) -->
            <Grid x:Name="MainContentGrid" Grid.Column="1" Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="280"/>
                </Grid.RowDefinitions>

                <!-- 1. Верхняя строка: Инфо-блок -->
                <TextBlock x:Name="TxtHostQuestionInfo" Grid.Row="0" 
                           Text="1000 ВОПРОС : 1" 
                           FontSize="48" FontWeight="ExtraBold" Foreground="#FFFF00" Margin="0,0,0,15"
                           FontFamily="Segoe UI Semibold"/>

                <!-- 2. Основной блок вопроса (PREMIUM GLASS LOOK) -->
                <Border Grid.Row="1" CornerRadius="12" BorderThickness="1" Padding="45">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#20FFFFFF" Offset="0"/>
                            <GradientStop Color="#05FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#40FFFFFF" Offset="0"/>
                            <GradientStop Color="#10FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <TextBlock x:Name="TxtQuestion" 
                               Text="ОЖИДАНИЕ ВОПРОСА ДЛЯ ВЕДУЩЕГО..." 
                               FontSize="88" FontWeight="Bold" Foreground="White" 
                               TextWrapping="Wrap" VerticalAlignment="Center"
                               FontFamily="Segoe UI" LineHeight="105">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="QuestionTransform" Y="0"/>
                        </TextBlock.RenderTransform>
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="Black" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </Border>

                <!-- 3. Блок ответа (Rich Crimson Gradient) -->
                <Border x:Name="AnswerBorder" Grid.Row="2" CornerRadius="8" Margin="0,15,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#8E0000" Offset="0"/>
                            <GradientStop Color="#C10000" Offset="0.5"/>
                            <GradientStop Color="#8E0000" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="AnswerTransform" Y="0"/>
                    </Border.RenderTransform>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.4"/>
                    </Border.Effect>
                    <TextBlock x:Name="TxtAnswer" 
                               Text="ПРАВИЛЬНЫЙ ОТВЕТ" 
                               FontSize="78" FontWeight="Bold" Foreground="White" 
                               TextWrapping="Wrap" FontFamily="Segoe UI"
                               Margin="40,20"/>
                </Border>

                <!-- 4. Нижняя информационная панель (Grid 2x4) -->
                <Grid x:Name="BottomInfoPanel" Grid.Row="3" Margin="0,40,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- СТРОКА 1 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="В БАНК" FontSize="36" FontWeight="SemiBold" Foreground="#888" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <Border Grid.Row="0" Grid.Column="1" CornerRadius="6" Background="#0000B8" Margin="5">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
                        </Border.Effect>
                        <TextBlock x:Name="TxtToBank" Text="1000" FontSize="72" FontWeight="ExtraBold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="ИЛИ ИГРАЕМ" FontSize="36" FontWeight="SemiBold" Foreground="#888" VerticalAlignment="Center" Margin="50,0,20,0"/>
                    <Border Grid.Row="0" Grid.Column="3" CornerRadius="6" Background="#800080" Margin="5">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
                        </Border.Effect>
                        <TextBlock x:Name="TxtNextSum" Text="2000" FontSize="72" FontWeight="ExtraBold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <!-- СТРОКА 2 -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="ТАЙМЕР" FontSize="36" FontWeight="SemiBold" Foreground="#888" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <Border Grid.Row="1" Grid.Column="1" CornerRadius="6" Background="#006400" Margin="5">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
                        </Border.Effect>
                        <Viewbox MaxWidth="280" MaxHeight="100" StretchDirection="DownOnly" Margin="10">
                            <TextBlock x:Name="TxtHostTimer" Text="2:30" FontSize="72" FontWeight="ExtraBold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Viewbox>
                    </Border>
                    
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="В БАНКЕ" FontSize="36" FontWeight="SemiBold" Foreground="#888" VerticalAlignment="Center" Margin="50,0,20,0"/>
                    <Border Grid.Row="1" Grid.Column="3" CornerRadius="6" Background="#4A0020" Margin="5">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
                        </Border.Effect>
                        <TextBlock x:Name="TxtHostBanked" Text="0" FontSize="72" FontWeight="ExtraBold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <!-- ПАНЕЛЬ ФИНАЛЬНОЙ ДУЭЛИ (ИНТЕГРИРОВАННАЯ В Row 3) -->
                <Grid x:Name="FinalDuelPanel" Grid.Row="3" Background="Transparent" Visibility="Collapsed" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Background="#20FFFFFF" CornerRadius="12" BorderThickness="1" BorderBrush="#30FFFFFF" Padding="20">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="TxtFinalist1Name" Text="ФИНАЛИСТ 1" FontSize="50" FontWeight="Bold" Foreground="#00CCCC" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            <StackPanel x:Name="StackP1Indicators" Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse x:Name="P1_I1" Width="35" Height="35" Fill="#111" Stroke="#444" Margin="8"/>
                                <Ellipse x:Name="P1_I2" Width="35" Height="35" Fill="#111" Stroke="#444" Margin="8"/>
                                <Ellipse x:Name="P1_I3" Width="35" Height="35" Fill="#111" Stroke="#444" Margin="8"/>
                                <Ellipse x:Name="P1_I4" Width="35" Height="35" Fill="#111" Stroke="#444" Margin="8"/>
                                <Ellipse x:Name="P1_I5" Width="35" Height="35" Fill="#111" Stroke="#444" Margin="8"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
 
                    <TextBlock Grid.Column="1" Text="VS" FontSize="60" FontWeight="Black" Foreground="#66FFFFFF" VerticalAlignment="Center" Margin="50,0"/>
 
                    <Border Grid.Column="2" Background="#20FFFFFF" CornerRadius="12" BorderThickness="1" BorderBrush="#30FFFFFF" Padding="20">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="TxtFinalist2Name" Text="ФИНАЛИСТ 2" FontSize="50" FontWeight="Bold" Foreground="#00CCCC" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            <StackPanel x:Name="StackP2Indicators" Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse x:Name="P2_I1" Width="35" Height="35" Fill="#111" Stroke="#444" Margin="8"/>
                                <Ellipse x:Name="P2_I2" Width="35" Height="35" Fill="#111" Stroke="#444" Margin="8"/>
                                <Ellipse x:Name="P2_I3" Width="35" Height="35" Fill="#111" Stroke="#444" Margin="8"/>
                                <Ellipse x:Name="P2_I4" Width="35" Height="35" Fill="#111" Stroke="#444" Margin="8"/>
                                <Ellipse x:Name="P2_I5" Width="35" Height="35" Fill="#111" Stroke="#444" Margin="8"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- СУФЛЁР / ПРАВИЛА — полупрозрачная подложка с крупным текстом по центру -->
            <Grid x:Name="HostRulesOverlay" Grid.ColumnSpan="2" Background="#CC000000" Visibility="Collapsed">
                <Border Background="#BB0A0A1A" Margin="80" CornerRadius="30" Padding="60" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="1600">
                    <TextBlock x:Name="TxtHostRules" Text="" FontSize="52" LineHeight="78" Foreground="White" TextWrapping="Wrap" TextAlignment="Center" FontFamily="Segoe UI" FontWeight="SemiBold"/>
                </Border>
            </Grid>

            <!-- Оверлей с логотипом (LOGO) -->
            <Grid x:Name="LogoOverlay" Grid.ColumnSpan="2" Background="Black" Visibility="Collapsed">
                <Image x:Name="ImgLogo" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="1200" MaxHeight="800"/>
            </Grid>

            <Grid x:Name="EliminationOverlay" Grid.ColumnSpan="2" Background="Black" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="ВЫБЫВАЕТ" FontSize="80" Foreground="#C10000" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,40"/>
                    <TextBlock x:Name="TxtEliminatedName" Text="PLAYER" FontSize="220" Foreground="White" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="ВЫ САМОЕ СЛАБОЕ ЗВЕНО. ПРОЩАЙТЕ!" FontSize="46" Foreground="#444" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,80,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Viewbox>
</Window>
