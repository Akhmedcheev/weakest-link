<Window x:Class="WeakestLink.Views.AudienceScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Audience Screen" Background="#0a0f1a"
        Width="1920" Height="1080"
        WindowStyle="None" ResizeMode="NoResize"
        WindowState="Maximized"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <!-- Viewbox масштабирует всё содержимое пропорционально экрану -->
    <Viewbox Stretch="Uniform">
        <Grid Width="1920" Height="1080">
            <Grid.ColumnDefinitions>
                <!-- Левая колонка: цепочка -->
                <ColumnDefinition Width="300"/>
                <!-- Разделитель -->
                <ColumnDefinition Width="3"/>
                <!-- Правая часть: информация -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── ФОНОВЫЙ ГРАДИЕНТ ── -->
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#050b18" Offset="0"/>
                    <GradientStop Color="#0a1428" Offset="0.5"/>
                    <GradientStop Color="#050b18" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- ── ЛЕВАЯ КОЛОНКА: ЦЕПОЧКА ── -->
            <Canvas x:Name="ChainCanvas"
                    Grid.Column="0"
                    ClipToBounds="False"
                    Margin="10,0,0,0"/>

            <!-- ── РАЗДЕЛИТЕЛЬ ── -->
            <Border Grid.Column="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#2255aa" Offset="0.3"/>
                        <GradientStop Color="#4488ee" Offset="0.5"/>
                        <GradientStop Color="#2255aa" Offset="0.7"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- ── ПРАВАЯ ЧАСТЬ ── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <!-- Заголовок: раунд и банк -->
                    <RowDefinition Height="120"/>
                    <!-- Имя игрока (главный элемент) -->
                    <RowDefinition Height="*"/>
                    <!-- Статус фазы внизу -->
                    <RowDefinition Height="130"/>
                </Grid.RowDefinitions>

                <!-- ЗАГОЛОВОК: РАУНД + БАНК -->
                <Border Grid.Row="0" Margin="20,16,20,0" CornerRadius="12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#10224a" Offset="0"/>
                            <GradientStop Color="#0d1d3e" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#0044cc" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="TxtRound"
                                   Text="РАУНД 1"
                                   FontFamily="Arial Black"
                                   FontSize="52"
                                   FontWeight="ExtraBold"
                                   Foreground="#FFD700"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" · "
                                   FontFamily="Arial Black"
                                   FontSize="40"
                                   Foreground="#445">
                        </TextBlock>
                        <TextBlock Text="БАНК: "
                                   FontFamily="Arial Black"
                                   FontSize="44"
                                   Foreground="#88aadd"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtBank"
                                   Text="0 ₽"
                                   FontFamily="Arial Black"
                                   FontSize="52"
                                   FontWeight="ExtraBold"
                                   Foreground="#00FF88"
                                   VerticalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#00ff88" BlurRadius="12" ShadowDepth="0" Opacity="0.6"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ХОД ИГРОКА: крупное имя по центру -->
                <Grid Grid.Row="1" Margin="20,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Viewbox Grid.Row="0" MaxWidth="900" VerticalAlignment="Center" HorizontalAlignment="Center"
                             Margin="0,10,0,10">
                        <TextBlock x:Name="TxtPlayerName"
                                   Text="—"
                                   FontFamily="Arial Black"
                                   FontSize="130"
                                   FontWeight="ExtraBold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#0066ff" BlurRadius="40" ShadowDepth="0" Opacity="0.8"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Viewbox>

                    <!-- Таймер (небольшой, под именем) -->
                    <Border Grid.Row="1" Margin="0,0,0,20" HorizontalAlignment="Center"
                            CornerRadius="28" Padding="40,8">
                        <Border.Background>
                            <SolidColorBrush Color="#0d1d3e"/>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#0088ff" BlurRadius="16" ShadowDepth="0" Opacity="0.5"/>
                        </Border.Effect>
                        <Viewbox>
                            <TextBlock x:Name="TxtTimer"
                                       Text="—:——"
                                       FontFamily="Arial Black"
                                       FontSize="64"
                                       FontWeight="ExtraBold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>
                        </Viewbox>
                    </Border>
                </Grid>

                <!-- СТАТУС ФАЗЫ: внизу -->
                <Border Grid.Row="2" Margin="20,0,20,16" CornerRadius="12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#10224a" Offset="0"/>
                            <GradientStop Color="#0d1d3e" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock x:Name="TxtPhase"
                               Text=""
                               FontFamily="Arial Black"
                               FontSize="52"
                               FontWeight="ExtraBold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"/>
                </Border>
            </Grid>

            <!-- ── ЛОГО-ОВЕРЛЕЙ ── -->
            <Grid x:Name="LogoOverlay"
                  Grid.ColumnSpan="3"
                  Background="#0a0f1a"
                  Visibility="Collapsed">
                <Image x:Name="ImgLogo"
                       Stretch="Uniform"
                       MaxWidth="1400" MaxHeight="900"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            </Grid>
        </Grid>
    </Viewbox>
</Window>
