<Window x:Class="WeakestLink.QuestionEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактор вопросов — Weakest Link" Height="750" Width="1000"
        Background="#1A1A1A" Foreground="White"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель файла и инструментов -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Файл:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="CmbFile" Width="180" Height="28" Margin="0,0,15,0" SelectionChanged="CmbFile_SelectionChanged">
                <ComboBoxItem Content="questions.json" IsSelected="True"/>
                <ComboBoxItem Content="final_questions.json"/>
            </ComboBox>
            <Button x:Name="BtnLoad" Content="Загрузить" Width="100" Height="32" Margin="0,0,5,0" Click="BtnLoad_Click"/>
            <Button x:Name="BtnSave" Content="Сохранить" Width="100" Height="32" Margin="0,0,5,0" Click="BtnSave_Click"/>
            <Button x:Name="BtnAdd" Content="Добавить" Width="90" Height="32" Margin="0,0,5,0" Click="BtnAdd_Click"/>
            <Button x:Name="BtnDelete" Content="Удалить" Width="90" Height="32" Margin="0,0,5,0" Click="BtnDelete_Click"/>
            <Button x:Name="BtnClear" Content="Очистить всё" Width="100" Height="32" Margin="0,0,5,0" Click="BtnClear_Click"/>
            <TextBlock x:Name="TxtStatus" Text="" Foreground="#888" VerticalAlignment="Center" Margin="15,0,0,0"/>
        </StackPanel>

        <!-- Поиск -->
        <TextBox x:Name="TxtSearch" Grid.Row="1" Height="28" Margin="0,0,0,8" 
                 Background="#222" Foreground="White" BorderBrush="#555"
                 TextChanged="TxtSearch_TextChanged"/>

        <!-- DataGrid с вопросами -->
        <DataGrid x:Name="QuestionsGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                  Background="#222" Foreground="White" GridLinesVisibility="Horizontal"
                  BorderThickness="1" BorderBrush="#444" Margin="0,0,0,10"
                  SelectionMode="Single" SelectionChanged="QuestionsGrid_SelectionChanged"
                  CanUserAddRows="False" CanUserDeleteRows="False">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#333"/>
                    <Setter Property="Foreground" Value="Yellow"/>
                    <Setter Property="Padding" Value="8,6"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="#222"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#0055AA"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#333"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Раунд" Binding="{Binding Round}" Width="60"/>
                <DataGridTextColumn Header="Текст" Binding="{Binding Text}" Width="*"/>
                <DataGridTextColumn Header="Ответ" Binding="{Binding CorrectAnswer}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Форма редактирования -->
        <GroupBox Grid.Row="3" Header="Редактирование выбранного вопроса" Foreground="Yellow" BorderBrush="#444" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Текст:" VerticalAlignment="Top" Margin="0,0,10,5"/>
                <TextBox x:Name="TxtEditText" Grid.Row="0" Grid.Column="1" Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                         Background="#111" Foreground="White" BorderBrush="#555" Margin="0,0,0,5"
                         VerticalScrollBarVisibility="Auto"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Ответ:" VerticalAlignment="Center" Margin="0,0,10,5"/>
                <TextBox x:Name="TxtEditAnswer" Grid.Row="1" Grid.Column="1" Height="28"
                         Background="#111" Foreground="White" BorderBrush="#555" Margin="0,0,0,5"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Раунд:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="TxtEditRound" Height="28" Width="80" HorizontalAlignment="Left"
                             Background="#111" Foreground="White" BorderBrush="#555"/>
                    <TextBlock Text="(0–7 или пусто)" Foreground="#666" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <Button Grid.Row="4" x:Name="BtnApplyEdit" Content="Применить изменения" Width="200" Height="36" 
                HorizontalAlignment="Left" Click="BtnApplyEdit_Click"/>
    </Grid>
</Window>
